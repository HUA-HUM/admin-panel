<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="lqa_login_layout_brand" inherit_id="web.login_layout" name="LQA Login Logo">
        <xpath expr="//div[contains(@class, 'text-center') and contains(@class, 'border-bottom')][1]" position="replace">
            <div class="text-center pb-3 border-bottom mb-4 o_lqa_login_logo_wrap">
                <img
                    src="/lqa_admin_panel/static/src/img/tienda-logo-navbar.png?v=3"
                    alt="Tienda Lo Quiero Aca"
                    class="o_lqa_login_logo"
                />
            </div>
        </xpath>
    </template>
</odoo>
