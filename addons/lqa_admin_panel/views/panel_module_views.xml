<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_lqa_panel_module_list" model="ir.ui.view">
        <field name="name">lqa.panel.module.list</field>
        <field name="model">lqa.panel.module</field>
        <field name="arch" type="xml">
            <list string="Modulos">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="dashboard_action_xmlid"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lqa_panel_module_form" model="ir.ui.view">
        <field name="name">lqa.panel.module.form</field>
        <field name="model">lqa.panel.module</field>
        <field name="arch" type="xml">
            <form string="Modulo">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="dashboard_action_xmlid"/>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Secciones">
                            <field name="section_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="status"/>
                                    <field name="badge"/>
                                    <field name="action_xmlid"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lqa_panel_section_list" model="ir.ui.view">
        <field name="name">lqa.panel.section.list</field>
        <field name="model">lqa.panel.section</field>
        <field name="arch" type="xml">
            <list string="Secciones">
                <field name="sequence" widget="handle"/>
                <field name="module_id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="status"/>
                <field name="badge"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lqa_panel_section_form" model="ir.ui.view">
        <field name="name">lqa.panel.section.form</field>
        <field name="model">lqa.panel.section</field>
        <field name="arch" type="xml">
            <form string="Seccion">
                <sheet>
                    <group>
                        <field name="module_id"/>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="status"/>
                        <field name="badge"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="action_xmlid"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lqa_panel_module" model="ir.actions.act_window">
        <field name="name">Modulos del panel</field>
        <field name="res_model">lqa.panel.module</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_lqa_panel_section" model="ir.actions.act_window">
        <field name="name">Secciones del panel</field>
        <field name="res_model">lqa.panel.section</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_lqa_config_modules"
        name="Modulos"
        parent="menu_lqa_config"
        action="action_lqa_panel_module"
        sequence="10"
        groups="lqa_admin_panel.group_lqa_admin"
    />

    <menuitem
        id="menu_lqa_config_sections"
        name="Secciones"
        parent="menu_lqa_config"
        action="action_lqa_panel_section"
        sequence="20"
        groups="lqa_admin_panel.group_lqa_admin"
    />
</odoo>
