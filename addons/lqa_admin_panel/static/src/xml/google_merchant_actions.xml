<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lqa_admin_panel.GoogleMerchantActions">
        <div class="o_lqa_google_actions">
            <header class="o_lqa_google_actions__header">
                <div>
                    <p>Retailers / Marketplaces / Google Merchant</p>
                    <h1>Acciones</h1>
                    <span>Operaciones administrativas sobre el catálogo conectado a la web.</span>
                </div>
                <img
                    src="/lqa_admin_panel/static/src/img/marketplace/google-merchant.png?v=1"
                    alt="Google Merchant"
                />
            </header>

            <nav class="o_lqa_google_actions_tabs" aria-label="Secciones Google Merchant">
                <button
                    type="button"
                    t-att-class="isPanel('publisher') ? 'is-active' : ''"
                    t-on-click="() => this.setPanel('publisher')"
                >
                    <i class="fa fa-cloud-upload"/>
                    Publicador
                </button>
                <button
                    type="button"
                    t-att-class="isPanel('deleter') ? 'is-active' : ''"
                    t-on-click="() => this.setPanel('deleter')"
                >
                    <i class="fa fa-trash-o"/>
                    Eliminador
                </button>
                <button
                    type="button"
                    t-att-class="isPanel('runs') ? 'is-active' : ''"
                    t-on-click="() => this.setPanel('runs')"
                >
                    <i class="fa fa-list-alt"/>
                    Registros de ejecución
                </button>
            </nav>

            <section t-if="isPanel('publisher')" class="o_lqa_google_actions_publish">
                <div class="o_lqa_google_actions_publish__icon">
                    <i class="fa fa-cloud-upload"/>
                </div>
                <div class="o_lqa_google_actions_publish__content">
                    <div class="o_lqa_google_actions_publish__head">
                        <div>
                            <small>Carga masiva</small>
                            <h2>Publicar productos</h2>
                        </div>
                        <span>Products API</span>
                    </div>
                    <p>
                        Dispara la publicación de todo el catálogo en Products API y deja el proceso corriendo en backend.
                        El backend continúa iterando páginas desde el offset indicado hasta que no haya más resultados.
                    </p>
                    <div class="o_lqa_google_actions_publish__form">
                        <label>
                            <span>Limit</span>
                            <input
                                type="number"
                                min="1"
                                class="form-control"
                                t-model="state.publishForm.limit"
                                t-att-disabled="state.publishing"
                            />
                        </label>
                        <label>
                            <span>Offset</span>
                            <input
                                type="number"
                                min="0"
                                class="form-control"
                                t-model="state.publishForm.offset"
                                t-att-disabled="state.publishing"
                            />
                        </label>
                        <button
                            type="button"
                            class="btn btn-primary"
                            t-att-disabled="!canPublish"
                            t-on-click="executePublishAll"
                        >
                            <i
                                t-att-class="state.publishing
                                    ? 'fa fa-spinner fa-spin'
                                    : 'fa fa-cloud-upload'"
                            />
                            <t t-esc="state.publishing ? 'Iniciando...' : 'Iniciar carga masiva'"/>
                        </button>
                    </div>
                </div>
            </section>

            <section t-if="isPanel('deleter')" class="o_lqa_google_actions_danger">
                <div class="o_lqa_google_actions_danger__icon">
                    <i class="fa fa-trash-o"/>
                </div>
                <div class="o_lqa_google_actions_danger__content">
                    <div class="o_lqa_google_actions_danger__head">
                        <div>
                            <small>Eliminador</small>
                            <h2>Eliminar productos</h2>
                        </div>
                        <span>Google Merchant</span>
                    </div>
                    <p>
                        Elimina productos puntuales usando SKU / ID de producto,
                        idioma de contenido y etiqueta de feed.
                    </p>

                    <div class="o_lqa_google_actions_delete_grid">
                        <article class="o_lqa_google_actions_delete_card">
                            <div>
                                <small>Manual</small>
                                <h3>Eliminar un producto</h3>
                                <p>Usa el endpoint individual de Marketplace API.</p>
                            </div>
                            <div class="o_lqa_google_actions_delete_form">
                                <label>
                                    <span>SKU / ID producto</span>
                                    <input
                                        type="text"
                                        class="form-control"
                                        placeholder="10059552187926859793"
                                        t-model="state.manualDelete.sku"
                                        t-att-disabled="state.deletingOne"
                                    />
                                </label>
                                <label>
                                    <span>Idioma</span>
                                    <input
                                        type="text"
                                        class="form-control"
                                        placeholder="es"
                                        t-model="state.manualDelete.contentLanguage"
                                        t-att-disabled="state.deletingOne"
                                    />
                                </label>
                                <label>
                                    <span>Feed label</span>
                                    <input
                                        type="text"
                                        class="form-control"
                                        placeholder="AR"
                                        t-model="state.manualDelete.feedLabel"
                                        t-att-disabled="state.deletingOne"
                                    />
                                </label>
                                <button
                                    type="button"
                                    class="btn btn-danger"
                                    t-att-disabled="!canDeleteOne"
                                    t-on-click="executeDeleteOne"
                                >
                                    <i
                                        t-att-class="state.deletingOne
                                            ? 'fa fa-spinner fa-spin'
                                            : 'fa fa-trash-o'"
                                    />
                                    <t t-esc="state.deletingOne ? 'Eliminando...' : 'Eliminar producto'"/>
                                </button>
                            </div>
                        </article>

                        <article class="o_lqa_google_actions_delete_card">
                            <div>
                                <small>Archivo</small>
                                <h3>Eliminar por CSV o XLSX</h3>
                                <p>
                                    Acepta columnas como ID de producto, Etiqueta de feed e Idioma.
                                    Tambien sirve sku, feedLabel y contentLanguage.
                                </p>
                            </div>
                            <div class="o_lqa_google_actions_download_box">
                                <div>
                                    <strong>Catálogo listo para eliminar</strong>
                                    <span>Descarga un XLSX con ID de producto, feed label e idioma.</span>
                                </div>
                                <button
                                    type="button"
                                    class="btn btn-secondary"
                                    t-att-disabled="!canDownloadCatalog"
                                    t-on-click="downloadDeleteCatalog"
                                >
                                    <i
                                        t-att-class="state.downloadingCatalog
                                            ? 'fa fa-spinner fa-spin'
                                            : 'fa fa-download'"
                                    />
                                    <t t-esc="state.downloadingCatalog ? 'Descargando...' : 'Descargar catálogo XLSX'"/>
                                </button>
                            </div>
                            <div class="o_lqa_google_actions_file_box">
                                <input
                                    type="file"
                                    accept=".csv,.xlsx"
                                    t-att-disabled="state.deletingFile"
                                    t-on-change="onDeleteFileChange"
                                />
                                <span t-if="state.deleteFile.filename" t-esc="state.deleteFile.filename"/>
                                <span t-else="">Selecciona un archivo CSV o XLSX</span>
                                <button
                                    type="button"
                                    class="btn btn-danger"
                                    t-att-disabled="!canDeleteFile"
                                    t-on-click="executeDeleteFile"
                                >
                                    <i
                                        t-att-class="state.deletingFile
                                            ? 'fa fa-spinner fa-spin'
                                            : 'fa fa-list'"
                                    />
                                    <t t-esc="state.deletingFile ? 'Encolando...' : 'Encolar eliminación'"/>
                                </button>
                            </div>
                        </article>

                        <article class="o_lqa_google_actions_delete_card is-critical">
                            <div>
                                <small>Zona crítica</small>
                                <h3>Eliminar todo el catálogo</h3>
                                <p>
                                    Esta acción solicita la eliminación de todos los productos
                                    publicados en Google Merchant.
                                </p>
                            </div>
                            <label for="lqa-google-delete-confirmation">
                                Escribí <strong>ELIMINAR TODO</strong> para confirmar
                            </label>
                            <div class="o_lqa_google_actions_danger__form">
                                <input
                                    id="lqa-google-delete-confirmation"
                                    type="text"
                                    class="form-control"
                                    autocomplete="off"
                                    placeholder="ELIMINAR TODO"
                                    t-model="state.confirmation"
                                    t-att-disabled="state.executing"
                                    t-on-keydown="onConfirmationKeydown"
                                />
                                <button
                                    type="button"
                                    class="btn btn-danger"
                                    t-att-disabled="!canExecute"
                                    t-on-click="executeDeleteAll"
                                >
                                    <i
                                        t-att-class="state.executing
                                            ? 'fa fa-spinner fa-spin'
                                            : 'fa fa-trash-o'"
                                    />
                                    <t t-esc="state.executing ? 'Eliminando...' : 'Eliminar catálogo'"/>
                                </button>
                            </div>
                        </article>
                    </div>
                </div>
            </section>

            <section t-if="isPanel('runs')" class="o_lqa_google_actions_history">
                <div class="o_lqa_google_actions_history__head">
                    <div>
                        <p>Registros de ejecución</p>
                        <h2>Historial de acciones</h2>
                    </div>
                    <button
                        type="button"
                        class="btn btn-secondary"
                        t-att-disabled="state.loadingHistory"
                        t-on-click="loadHistory"
                    >
                        <i class="fa fa-refresh"/>
                        Refrescar registros
                    </button>
                </div>

                <div
                    t-if="state.loadingHistory"
                    class="o_lqa_google_actions_history__empty"
                >
                    Cargando historial...
                </div>
                <div
                    t-elif="!state.history.length"
                    class="o_lqa_google_actions_history__empty"
                >
                    No hay ejecuciones registradas.
                </div>
                <div t-else="" class="o_lqa_google_actions_history__list">
                    <article
                        class="o_lqa_google_actions_run"
                        t-foreach="state.history"
                        t-as="run"
                        t-key="run.id"
                    >
                        <div class="o_lqa_google_actions_run__main">
                            <span
                                t-att-class="'o_lqa_google_actions_run__status is-' + run.status"
                            >
                                <i
                                    t-att-class="run.status === 'completed'
                                        ? 'fa fa-check'
                                        : run.status === 'partial'
                                            ? 'fa fa-exclamation-triangle'
                                        : run.status === 'failed'
                                            ? 'fa fa-times'
                                            : 'fa fa-clock-o'"
                                />
                            </span>
                            <div>
                                <small t-esc="formatDateTime(run.triggered_at)"/>
                                <h3 t-esc="actionLabel(run.action_type)"/>
                                <p t-esc="actionDetail(run)"/>
                            </div>
                        </div>
                        <div class="o_lqa_google_actions_run__meta">
                            <span t-esc="run.user_name || 'Usuario'"/>
                            <strong
                                t-att-class="'is-' + run.status"
                                t-esc="statusLabel(run.status)"
                            />
                            <button
                                t-if="run.response_json"
                                type="button"
                                t-att-title="state.expandedResponses[run.id]
                                    ? 'Ocultar respuesta'
                                    : 'Ver respuesta'"
                                t-att-aria-label="state.expandedResponses[run.id]
                                    ? 'Ocultar respuesta'
                                    : 'Ver respuesta'"
                                t-on-click="() => this.toggleResponse(run)"
                            >
                                <i
                                    t-att-class="state.expandedResponses[run.id]
                                        ? 'fa fa-chevron-up'
                                        : 'fa fa-code'"
                                />
                            </button>
                        </div>
                        <pre
                            t-if="state.expandedResponses[run.id] &amp;&amp; run.response_json"
                            t-esc="run.response_json"
                        />
                    </article>
                </div>
            </section>
        </div>
    </t>
</templates>
