<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lqa_admin_panel.MercadolibreCatalog">
        <div class="o_lqa_meli_catalog">
            <header class="o_lqa_meli_catalog__header">
                <div>
                    <p>MercadoLibre</p>
                    <h1>Catalogo de productos</h1>
                    <span>
                        Rendimiento comercial, stock, visitas y ventas de las publicaciones.
                    </span>
                </div>
                <img
                    src="/lqa_admin_panel/static/src/img/mercadolibre-logo.png?v=2"
                    alt="Mercado Libre"
                />
            </header>

            <form
                class="o_lqa_meli_filters"
                t-on-submit.prevent="applyFilters"
            >
                <div class="o_lqa_meli_filters__heading">
                    <div>
                        <h2>Filtros</h2>
                        <span>Combina los campos para refinar el catalogo.</span>
                    </div>
                    <div class="o_lqa_meli_filters__actions">
                        <button
                            type="button"
                            class="btn btn-secondary"
                            t-on-click="clearFilters"
                        >
                            Limpiar
                        </button>
                        <button type="submit" class="btn btn-primary">
                            Aplicar filtros
                        </button>
                    </div>
                </div>

                <div class="o_lqa_meli_filters__grid">
                    <label class="is-wide">
                        <span>Buscar</span>
                        <input
                            type="search"
                            class="form-control"
                            placeholder="Titulo, SKU o publicacion"
                            t-model="state.filters.search"
                        />
                    </label>
                    <label>
                        <span>Marcas</span>
                        <input
                            type="text"
                            class="form-control"
                            placeholder="Samsung,Sony"
                            t-model="state.filters.brand"
                        />
                    </label>
                    <label>
                        <span>Categoria</span>
                        <input
                            type="text"
                            class="form-control"
                            placeholder="MLA1002"
                            t-model="state.filters.categoryId"
                        />
                    </label>
                    <label>
                        <span>Dominio</span>
                        <input
                            type="text"
                            class="form-control"
                            placeholder="MLA-TELEVISIONS"
                            t-model="state.filters.domainId"
                        />
                    </label>
                    <label>
                        <span>Estado</span>
                        <select class="form-select" t-model="state.filters.status">
                            <option value="">Todos</option>
                            <option value="active">Activa</option>
                            <option value="paused">Pausada</option>
                            <option value="closed">Cerrada</option>
                        </select>
                    </label>
                    <label>
                        <span>Condicion</span>
                        <select class="form-select" t-model="state.filters.condition">
                            <option value="">Todas</option>
                            <option value="new">Nuevo</option>
                            <option value="used">Usado</option>
                            <option value="refurbished">Reacondicionado</option>
                        </select>
                    </label>
                    <label>
                        <span>Prefijo SKU</span>
                        <input
                            type="text"
                            class="form-control"
                            placeholder="B0"
                            t-model="state.filters.skuPrefix"
                        />
                    </label>
                    <label>
                        <span>Con ordenes</span>
                        <select class="form-select" t-model="state.filters.hasOrders">
                            <option value="">Todos</option>
                            <option value="true">Si</option>
                            <option value="false">No</option>
                        </select>
                    </label>
                    <label>
                        <span>Con visitas</span>
                        <select class="form-select" t-model="state.filters.hasVisits">
                            <option value="">Todos</option>
                            <option value="true">Si</option>
                            <option value="false">No</option>
                        </select>
                    </label>
                    <label>
                        <span>Ordenes minimas</span>
                        <input
                            type="number"
                            min="0"
                            class="form-control"
                            placeholder="1"
                            t-model="state.filters.minOrders"
                        />
                    </label>
                    <label>
                        <span>Facturacion minima</span>
                        <input
                            type="number"
                            min="0"
                            class="form-control"
                            placeholder="100000"
                            t-model="state.filters.minRevenue"
                        />
                    </label>
                    <label>
                        <span>Creado desde</span>
                        <input
                            type="date"
                            class="form-control"
                            t-model="state.filters.createdFrom"
                        />
                    </label>
                    <label>
                        <span>Creado hasta</span>
                        <input
                            type="date"
                            class="form-control"
                            t-model="state.filters.createdTo"
                        />
                    </label>
                    <label>
                        <span>Ordenar por</span>
                        <select class="form-select" t-model="state.filters.sortBy">
                            <option value="revenue">Facturacion</option>
                            <option value="ordersCount">Ordenes</option>
                            <option value="unitsSold">Unidades vendidas</option>
                            <option value="totalVisits">Visitas</option>
                            <option value="orderConversionRate">Conversion</option>
                            <option value="price">Precio</option>
                            <option value="stock">Stock</option>
                            <option value="catalogSoldQuantity">Ventas catalogo</option>
                            <option value="daysToFirstOrder">Dias a primera venta</option>
                            <option value="dateCreated">Fecha de creacion</option>
                            <option value="lastUpdated">Ultima actualizacion</option>
                            <option value="title">Titulo</option>
                            <option value="brand">Marca</option>
                            <option value="sku">SKU</option>
                            <option value="itemId">ID publicacion</option>
                            <option value="categoryId">Categoria</option>
                            <option value="domainId">Dominio</option>
                            <option value="status">Estado</option>
                            <option value="availableQuantity">Stock disponible</option>
                            <option value="avgTicket">Ticket promedio</option>
                            <option value="firstOrderDate">Primera orden</option>
                            <option value="lastOrderDate">Ultima orden</option>
                            <option value="unitConversionRate">Conversion unidades</option>
                        </select>
                    </label>
                    <label>
                        <span>Direccion</span>
                        <select class="form-select" t-model="state.filters.sortOrder">
                            <option value="desc">Descendente</option>
                            <option value="asc">Ascendente</option>
                        </select>
                    </label>
                    <label>
                        <span>Productos por pagina</span>
                        <select class="form-select" t-model="state.filters.limit">
                            <option value="24">24</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </label>
                </div>
            </form>

            <details class="o_lqa_meli_selections">
                <summary class="o_lqa_meli_selections__head">
                    <div>
                        <h2>Selecciones de productos</h2>
                        <span>
                            Guarda publicaciones del catalogo en carpetas para analizarlas despues.
                        </span>
                    </div>
                    <div class="o_lqa_meli_selections__summary">
                        <strong>
                            <t t-esc="formatNumber(selectedCount)"/>
                            seleccionados
                        </strong>
                        <i class="fa fa-chevron-down"/>
                    </div>
                </summary>

                <div class="o_lqa_meli_selections__tools">
                    <form t-on-submit.prevent="createFolder">
                        <label>
                            <span>Nueva carpeta</span>
                            <input
                                type="text"
                                class="form-control"
                                placeholder="Ej: publicaciones a revisar"
                                t-model="state.newFolderName"
                            />
                        </label>
                        <button type="submit" class="btn btn-secondary">
                            Crear
                        </button>
                    </form>

                    <div class="o_lqa_meli_save_box">
                        <label>
                            <span>Guardar en carpeta</span>
                            <select
                                class="form-select"
                                t-model="state.selectedFolderId"
                                t-on-change="() => this.selectFolder(state.selectedFolderId)"
                            >
                                <option value="">Elegir carpeta</option>
                                <option
                                    t-foreach="state.folders"
                                    t-as="folder"
                                    t-key="folder.id"
                                    t-att-value="folder.id"
                                >
                                    <t t-esc="folder.name"/>
                                    (<t t-esc="formatNumber(folder.productCount)"/>)
                                </option>
                            </select>
                        </label>
                        <button
                            type="button"
                            class="btn btn-primary"
                            t-att-disabled="!selectedCount || !state.selectedFolderId || state.savingSelection"
                            t-on-click="saveSelectionToFolder"
                        >
                            <t t-if="state.savingSelection">Guardando...</t>
                            <t t-else="">Guardar seleccion</t>
                        </button>
                        <button
                            type="button"
                            class="btn btn-secondary"
                            t-att-disabled="!selectedCount"
                            t-on-click="clearSelection"
                        >
                            Limpiar seleccion
                        </button>
                    </div>
                </div>

                <div class="o_lqa_meli_folder_chips" t-if="state.folders.length">
                    <button
                        type="button"
                        t-foreach="state.folders"
                        t-as="folder"
                        t-key="folder.id"
                        t-att-class="isFolderSelected(folder) ? 'is-active' : ''"
                        t-on-click="() => this.selectFolder(folder.id)"
                    >
                        <span t-esc="folder.name"/>
                        <strong t-esc="formatNumber(folder.productCount)"/>
                    </button>
                </div>
                <div class="o_lqa_meli_empty_inline" t-elif="!state.foldersLoading">
                    Todavia no hay carpetas creadas.
                </div>

                <div class="o_lqa_meli_saved" t-if="state.selectedFolderId">
                    <div class="o_lqa_meli_saved__head">
                        <div>
                            <h3 t-esc="selectedFolder ? selectedFolder.name : 'Carpeta'"/>
                            <span>
                                <t t-esc="formatNumber(state.folderPagination.total || 0)"/>
                                productos guardados
                            </span>
                        </div>
                        <button
                            type="button"
                            class="btn btn-secondary"
                            t-att-disabled="state.folderProductsLoading"
                            t-on-click="loadFolderProducts"
                        >
                            <i class="fa fa-refresh"/>
                            Actualizar
                        </button>
                    </div>
                    <div class="o_lqa_meli_empty_inline" t-if="state.folderProductsLoading">
                        Cargando productos guardados...
                    </div>
                    <div class="o_lqa_meli_empty_inline" t-elif="!state.folderProducts.length">
                        Esta carpeta todavia no tiene productos.
                    </div>
                    <div class="o_lqa_meli_saved_grid" t-else="">
                        <article
                            t-foreach="state.folderProducts"
                            t-as="saved"
                            t-key="saved.id"
                        >
                            <div>
                                <span
                                    t-att-class="'o_lqa_meli_saved_status is-' + saved.status"
                                    t-esc="statusLabel(saved.status)"
                                />
                                <button
                                    type="button"
                                    title="Quitar"
                                    t-on-click="() => this.removeSavedProduct(saved)"
                                >
                                    <i class="fa fa-trash-o"/>
                                </button>
                            </div>
                            <strong t-esc="saved.item_id || 'Sin MLA'"/>
                            <small t-esc="saved.sku || 'Sin SKU'"/>
                            <dl>
                                <div>
                                    <dt>Precio</dt>
                                    <dd t-esc="formatCurrency(saved.price, saved.currency_id)"/>
                                </div>
                                <div>
                                    <dt>Facturacion</dt>
                                    <dd t-esc="formatCurrency(saved.revenue, saved.currency_id)"/>
                                </div>
                                <div>
                                    <dt>Ordenes</dt>
                                    <dd t-esc="formatNumber(saved.orders_count)"/>
                                </div>
                                <div>
                                    <dt>Actualizado</dt>
                                    <dd t-esc="formatDateTime(saved.last_updated)"/>
                                </div>
                            </dl>
                        </article>
                    </div>
                </div>
            </details>

            <section class="o_lqa_meli_results">
                <div class="o_lqa_meli_results__bar">
                    <div>
                        <strong t-esc="formatNumber(state.pagination.total || 0)"/>
                        <span>productos encontrados</span>
                    </div>
                    <div t-if="state.pagination.total_pages">
                        Pagina
                        <strong t-esc="state.pagination.page"/>
                        de
                        <strong t-esc="formatNumber(state.pagination.total_pages)"/>
                    </div>
                </div>

                <div class="o_lqa_meli_bulk_actions" t-if="state.products.length">
                    <div>
                        <button
                            type="button"
                            class="btn btn-secondary"
                            t-on-click="selectCurrentPage"
                        >
                            <i class="fa fa-check-square-o"/>
                            Seleccionar pagina
                        </button>
                        <button
                            type="button"
                            class="btn btn-secondary"
                            t-att-disabled="!selectedCount"
                            t-on-click="clearSelection"
                        >
                            Limpiar seleccion
                        </button>
                    </div>
                    <div>
                        <span>
                            <strong t-esc="selectedCount"/>
                            seleccionados
                        </span>
                        <button
                            type="button"
                            class="btn btn-danger"
                            t-att-disabled="!selectedCount"
                            t-on-click="openDeleteConfirmation"
                        >
                            <i class="fa fa-trash"/>
                            Eliminar seleccionados
                        </button>
                    </div>
                </div>

                <div class="o_lqa_meli_loading" t-if="state.loading">
                    Cargando productos...
                </div>

                <div class="o_lqa_meli_empty" t-elif="!state.products.length">
                    No hay productos para los filtros seleccionados.
                </div>

                <div class="o_lqa_meli_products" t-else="">
                    <article
                        t-att-class="{
                            'o_lqa_meli_product': true,
                            'is-selected': isSelected(productKey(product)),
                        }"
                        t-foreach="state.products"
                        t-as="product"
                        t-key="product.item_id"
                    >
                        <div class="o_lqa_meli_product__image">
                            <label class="o_lqa_meli_product__select">
                                <input
                                    type="checkbox"
                                    t-att-checked="isSelected(productKey(product))"
                                    t-on-change="(event) => this.toggleProductSelection(event, product)"
                                />
                                <span>
                                    <i class="fa fa-check"/>
                                </span>
                                <small>Seleccionar</small>
                            </label>
                            <img
                                t-if="product.thumbnail"
                                t-att-src="product.thumbnail"
                                t-att-alt="product.title"
                                loading="lazy"
                            />
                            <img
                                t-else=""
                                src="/lqa_admin_panel/static/src/img/mercadolibre-logo.png?v=2"
                                alt="Mercado Libre"
                            />
                            <span
                                t-att-class="'o_lqa_meli_status is-' + product.status"
                                t-esc="statusLabel(product.status)"
                            />
                        </div>

                        <div class="o_lqa_meli_product__content">
                            <div class="o_lqa_meli_product__identity">
                                <span t-esc="product.brand || 'Sin marca'"/>
                                <span t-esc="product.item_id"/>
                            </div>
                            <h2 t-esc="product.title"/>
                            <p>
                                <span t-esc="product.sku || 'Sin SKU'"/>
                                <span t-esc="product.condition"/>
                            </p>

                            <div class="o_lqa_meli_product__price">
                                <strong
                                    t-esc="formatCurrency(product.price, product.currency_id)"
                                />
                                <span>
                                    Stock:
                                    <b t-esc="formatNumber(product.available_quantity)"/>
                                </span>
                            </div>

                            <dl class="o_lqa_meli_product__metrics">
                                <div>
                                    <dt>Facturacion</dt>
                                    <dd
                                        t-esc="formatCurrency(product.revenue, product.currency_id)"
                                    />
                                </div>
                                <div>
                                    <dt>Ordenes</dt>
                                    <dd t-esc="formatNumber(product.orders_count)"/>
                                </div>
                                <div>
                                    <dt>Unidades</dt>
                                    <dd t-esc="formatNumber(product.units_sold)"/>
                                </div>
                                <div>
                                    <dt>Visitas</dt>
                                    <dd t-esc="formatNumber(product.total_visits)"/>
                                </div>
                                <div>
                                    <dt>Conversion</dt>
                                    <dd t-esc="formatPercent(product.order_conversion_rate)"/>
                                </div>
                                <div>
                                    <dt>Creado</dt>
                                    <dd t-esc="formatDate(product.date_created)"/>
                                </div>
                            </dl>
                        </div>

                        <footer class="o_lqa_meli_product__footer">
                            <span>
                                <t t-esc="product.category_id"/>
                            </span>
                            <a
                                t-if="product.permalink"
                                t-att-href="product.permalink"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                Ver publicacion
                            </a>
                        </footer>
                    </article>
                </div>

                <div class="o_lqa_meli_pagination" t-if="state.products.length">
                    <button
                        type="button"
                        class="btn btn-secondary"
                        t-att-disabled="!state.pagination.has_previous"
                        t-on-click="previousPage"
                    >
                        Anterior
                    </button>
                    <span>
                        Mostrando
                        <strong t-esc="formatNumber(state.products.length)"/>
                        productos
                    </span>
                    <button
                        type="button"
                        class="btn btn-primary"
                        t-att-disabled="!state.pagination.has_next"
                        t-on-click="nextPage"
                    >
                        Siguiente
                    </button>
                </div>
            </section>

            <div class="o_lqa_delete_modal" t-if="state.showDeleteConfirmation">
                <button
                    type="button"
                    class="o_lqa_delete_modal__backdrop"
                    aria-label="Cancelar eliminacion"
                    t-on-click="closeDeleteConfirmation"
                />
                <section role="dialog" aria-modal="true" aria-labelledby="catalog-delete-title">
                    <div class="o_lqa_delete_modal__icon">
                        <i class="fa fa-exclamation-triangle"/>
                    </div>
                    <h2 id="catalog-delete-title">Eliminar publicaciones seleccionadas</h2>
                    <p>
                        Vas a eliminar
                        <strong t-esc="selectedCount"/>
                        publicaciones de MercadoLibre. La ejecucion quedara registrada en la seccion Eliminador.
                    </p>
                    <label class="o_lqa_meli_delete_app_key">
                        <span>App key</span>
                        <input
                            type="text"
                            class="form-control"
                            t-model="state.appKey"
                        />
                    </label>
                    <div class="o_lqa_delete_modal__actions">
                        <button
                            type="button"
                            class="btn btn-secondary"
                            t-att-disabled="state.deleting"
                            t-on-click="closeDeleteConfirmation"
                        >
                            Cancelar
                        </button>
                        <button
                            type="button"
                            class="btn btn-danger"
                            t-att-disabled="state.deleting"
                            t-on-click="confirmSelectedDeletion"
                        >
                            <t t-if="state.deleting">Procesando...</t>
                            <t t-else="">Si, eliminar</t>
                        </button>
                    </div>
                </section>
            </div>
        </div>
    </t>
</templates>
