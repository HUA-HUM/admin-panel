<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lqa_admin_panel.RetailersPublisherExecute">
        <div class="o_lqa_retailers_publish">
            <header class="o_lqa_retailers_publish__header">
                <div>
                    <p>Retailers / Publicador</p>
                    <h1>Publicar</h1>
                    <span>Crear un publication run desde una carpeta de Madre.</span>
                </div>
                <button
                    type="button"
                    class="btn btn-secondary"
                    t-att-disabled="state.loadingFolders"
                    t-on-click="loadFolders"
                >
                    <i class="fa fa-refresh"/>
                    Actualizar carpetas
                </button>
            </header>

            <section class="o_lqa_retailers_publish_form">
                <div class="o_lqa_retailers_publish_step">
                    <div class="o_lqa_retailers_publish_step__number">1</div>
                    <div class="o_lqa_retailers_publish_step__content">
                        <label for="lqa-publication-folder">Carpeta de productos</label>
                        <select
                            id="lqa-publication-folder"
                            class="form-select"
                            t-model="state.selectedFolderId"
                            t-att-disabled="state.loadingFolders || !state.folders.length"
                        >
                            <option value="">Seleccionar carpeta</option>
                            <option
                                t-foreach="state.folders"
                                t-as="folder"
                                t-key="folder.id"
                                t-att-value="String(folder.id)"
                            >
                                <t t-esc="folder.name"/>
                            </option>
                        </select>
                    </div>
                </div>

                <div class="o_lqa_retailers_publish_step">
                    <div class="o_lqa_retailers_publish_step__number">2</div>
                    <div class="o_lqa_retailers_publish_step__content">
                        <label>Marketplaces</label>
                        <div class="o_lqa_retailers_publish_marketplaces">
                            <button
                                type="button"
                                t-foreach="state.marketplaces"
                                t-as="marketplace"
                                t-key="marketplace.id"
                                t-att-class="isMarketplaceSelected(marketplace) ? 'is-selected' : ''"
                                t-on-click="() => this.toggleMarketplace(marketplace)"
                            >
                                <span class="o_lqa_retailers_publish_marketplace__check">
                                    <i
                                        t-att-class="isMarketplaceSelected(marketplace)
                                            ? 'fa fa-check'
                                            : 'fa fa-circle-o'"
                                    />
                                </span>
                                <img
                                    t-att-src="marketplace.logo"
                                    t-att-alt="marketplace.name"
                                />
                                <strong t-esc="marketplace.name"/>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="o_lqa_retailers_publish_submit">
                    <div>
                        <small>Seleccionados</small>
                        <strong t-esc="selectedMarketplaceNames || 'Ninguno'"/>
                    </div>
                    <button
                        type="button"
                        class="btn btn-primary"
                        t-att-disabled="!selectedFolder || !selectedMarketplaceIds.length || state.executing"
                        t-on-click="openExecutionConfirmation"
                    >
                        <i class="fa fa-cloud-upload"/>
                        Ejecutar publicacion
                    </button>
                </div>
            </section>

            <section class="o_lqa_retailers_publish_history">
                <div class="o_lqa_retailers_publish_history__head">
                    <div>
                        <h2>Respuestas guardadas</h2>
                        <span>Historial persistente de ejecuciones de publicación.</span>
                    </div>
                    <button
                        type="button"
                        class="btn btn-secondary"
                        t-att-disabled="state.loadingHistory"
                        t-on-click="loadPublicationHistory"
                    >
                        <i class="fa fa-refresh"/>
                        Actualizar
                    </button>
                </div>

                <div
                    t-if="state.loadingHistory"
                    class="o_lqa_retailers_publish_history__empty"
                >
                    Cargando respuestas...
                </div>
                <div
                    t-elif="!state.history.length"
                    class="o_lqa_retailers_publish_history__empty"
                >
                    Todavía no hay ejecuciones guardadas.
                </div>
                <div t-else="" class="o_lqa_retailers_publish_history__list">
                    <article
                        class="o_lqa_retailers_publish_result"
                        t-foreach="state.history"
                        t-as="execution"
                        t-key="execution.id"
                    >
                        <div class="o_lqa_retailers_publish_result__head">
                            <div>
                                <small t-esc="execution.user_name || 'Usuario'"/>
                                <h2>
                                    Run
                                    <t t-esc="execution.run_id || 'sin ID'"/>
                                </h2>
                            </div>
                            <strong t-esc="statusLabel(execution.status)"/>
                        </div>
                        <dl>
                            <div>
                                <dt>Carpeta</dt>
                                <dd t-esc="execution.folder_id"/>
                            </div>
                            <div>
                                <dt>Marketplaces</dt>
                                <dd>
                                    <t
                                        t-foreach="execution.marketplaces"
                                        t-as="marketplaceId"
                                        t-key="marketplaceId"
                                    >
                                        <span t-esc="marketplaceName(marketplaceId)"/>
                                    </t>
                                </dd>
                            </div>
                            <div>
                                <dt>Jobs</dt>
                                <dd t-esc="formatNumber(execution.jobs_count)"/>
                            </div>
                            <div>
                                <dt>Fecha</dt>
                                <dd t-esc="formatDateTime(execution.triggered_at)"/>
                            </div>
                        </dl>
                        <p t-if="execution.message" t-esc="execution.message"/>
                    </article>
                </div>
            </section>

            <div class="o_lqa_modal_backdrop" t-if="state.confirmExecution">
                <div class="o_lqa_retailers_publish_modal">
                    <h2>Confirmar publicacion</h2>
                    <p>
                        Vas a publicar los productos de
                        <strong t-esc="selectedFolder.name"/>
                        en
                        <strong t-esc="selectedMarketplaceNames"/>.
                    </p>
                    <div class="o_lqa_retailers_publish_modal__actions">
                        <button
                            type="button"
                            class="btn btn-secondary"
                            t-att-disabled="state.executing"
                            t-on-click="closeExecutionConfirmation"
                        >
                            Cancelar
                        </button>
                        <button
                            type="button"
                            class="btn btn-primary"
                            t-att-disabled="state.executing"
                            t-on-click="confirmExecutePublication"
                        >
                            Crear publication run
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
