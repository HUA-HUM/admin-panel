<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lqa_admin_panel.RetailersPublisher">
        <div class="o_lqa_retailers_publisher">
            <header class="o_lqa_retailers_publisher__header">
                <div>
                    <p>Retailers / Publicador</p>
                    <h1>Carpetas</h1>
                    <span>Selecciones de productos guardadas en Madre.</span>
                </div>
                <button
                    type="button"
                    class="btn btn-secondary"
                    t-att-disabled="state.loadingFolders"
                    t-on-click="loadFolders"
                >
                    <i class="fa fa-refresh"/>
                    Actualizar
                </button>
            </header>

            <nav class="o_lqa_retailers_publisher__tabs">
                <button type="button" class="is-active">
                    <i class="fa fa-folder-open-o"/>
                    Carpetas
                </button>
            </nav>

            <form
                class="o_lqa_retailers_publisher_create"
                t-on-submit.prevent="createFolder"
            >
                <div>
                    <label for="lqa-publisher-folder-name">Nueva carpeta</label>
                    <input
                        id="lqa-publisher-folder-name"
                        type="text"
                        maxlength="120"
                        placeholder="Nombre de la carpeta"
                        t-model="state.newFolderName"
                    />
                </div>
                <button
                    type="submit"
                    class="btn btn-primary"
                    t-att-disabled="state.creatingFolder"
                >
                    <i class="fa fa-plus"/>
                    Crear carpeta
                </button>
            </form>

            <section class="o_lqa_retailers_publisher_layout">
                <aside class="o_lqa_retailers_publisher_folders">
                    <div class="o_lqa_retailers_publisher_folders__head">
                        <h2>Carpetas</h2>
                        <span>
                            <t t-esc="formatNumber(state.folders.length)"/>
                            disponibles
                        </span>
                    </div>

                    <div
                        t-if="state.loadingFolders"
                        class="o_lqa_retailers_publisher_empty"
                    >
                        Cargando carpetas...
                    </div>
                    <div
                        t-elif="!state.folders.length"
                        class="o_lqa_retailers_publisher_empty"
                    >
                        No hay carpetas creadas.
                    </div>
                    <div t-else="" class="o_lqa_retailers_publisher_folder_list">
                        <button
                            type="button"
                            t-foreach="state.folders"
                            t-as="folder"
                            t-key="folder.id"
                            t-att-class="isSelectedFolder(folder) ? 'is-active' : ''"
                            t-on-click="() => this.selectFolder(folder)"
                        >
                            <strong t-esc="folder.name"/>
                            <span>
                                <t t-esc="formatNumber(folder.product_count)"/>
                                productos
                            </span>
                            <small>
                                ID
                                <t t-esc="folder.id"/>
                            </small>
                        </button>
                    </div>
                </aside>

                <section class="o_lqa_retailers_publisher_detail">
                    <div
                        t-if="!selectedFolder"
                        class="o_lqa_retailers_publisher_empty is-large"
                    >
                        Selecciona o crea una carpeta.
                    </div>

                    <t t-else="">
                        <div class="o_lqa_retailers_publisher_detail__head">
                            <div>
                                <p>Carpeta seleccionada</p>
                                <h2 t-esc="selectedFolder.name"/>
                                <span>
                                    Folder ID:
                                    <strong t-esc="selectedFolder.id"/>
                                </span>
                            </div>
                            <strong class="o_lqa_retailers_publisher_count">
                                <t t-esc="formatNumber(selectedFolder.product_count)"/>
                                productos
                            </strong>
                        </div>

                        <div class="o_lqa_retailers_publisher_inputs">
                            <form
                                class="o_lqa_retailers_publisher_manual"
                                t-on-submit.prevent="addManualProduct"
                            >
                                <div class="o_lqa_retailers_publisher_form_head">
                                    <i class="fa fa-keyboard-o"/>
                                    <div>
                                        <small>Carga manual</small>
                                        <h3>Agregar producto</h3>
                                    </div>
                                </div>
                                <label>
                                    <span>Product ID / MLA</span>
                                    <input
                                        type="text"
                                        placeholder="MLA123456789"
                                        t-model="state.manual.productId"
                                    />
                                </label>
                                <label>
                                    <span>Seller SKU</span>
                                    <input
                                        type="text"
                                        placeholder="SKU-001"
                                        t-model="state.manual.sellerSku"
                                    />
                                </label>
                                <button
                                    type="submit"
                                    class="btn btn-primary"
                                    t-att-disabled="state.addingManual"
                                >
                                    <i class="fa fa-plus"/>
                                    Agregar a la carpeta
                                </button>
                            </form>

                            <form
                                class="o_lqa_retailers_publisher_import"
                                t-on-submit.prevent="importFile"
                            >
                                <div class="o_lqa_retailers_publisher_form_head">
                                    <i class="fa fa-file-excel-o"/>
                                    <div>
                                        <small>Carga masiva</small>
                                        <h3>Importar productos</h3>
                                    </div>
                                </div>
                                <label class="o_lqa_retailers_publisher_file">
                                    <input
                                        type="file"
                                        accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                                        t-on-change="onFileChange"
                                    />
                                    <span>
                                        <i class="fa fa-upload"/>
                                        <t t-esc="state.upload.name || 'Seleccionar Excel XLSX'"/>
                                    </span>
                                </label>
                                <div class="o_lqa_retailers_publisher_import_actions">
                                    <button
                                        type="button"
                                        class="btn btn-secondary"
                                        t-att-disabled="state.downloadingTemplate"
                                        t-on-click="downloadTemplate"
                                    >
                                        <i class="fa fa-download"/>
                                        Plantilla Excel
                                    </button>
                                    <button
                                        type="submit"
                                        class="btn btn-primary"
                                        t-att-disabled="!state.upload.content || state.importingFile"
                                    >
                                        <i class="fa fa-upload"/>
                                        Importar
                                    </button>
                                </div>
                            </form>
                        </div>

                        <div class="o_lqa_retailers_publisher_products">
                            <div class="o_lqa_retailers_publisher_products__head">
                                <div>
                                    <h3>Productos de la carpeta</h3>
                                    <span>
                                        <t t-esc="formatNumber(state.pagination.total || 0)"/>
                                        productos
                                    </span>
                                </div>
                                <div class="o_lqa_retailers_publisher_products__actions">
                                    <button
                                        type="button"
                                        class="btn btn-secondary"
                                        t-on-click="toggleFilters"
                                    >
                                        <i class="fa fa-filter"/>
                                        Filtros
                                    </button>
                                    <button
                                        type="button"
                                        class="btn btn-danger"
                                        t-att-disabled="!selectedProductIds.length"
                                        t-on-click="openDeleteConfirmation"
                                    >
                                        <i class="fa fa-trash-o"/>
                                        Eliminar
                                        <t t-if="selectedProductIds.length">
                                            (<t t-esc="formatNumber(selectedProductIds.length)"/>)
                                        </t>
                                    </button>
                                </div>
                            </div>

                            <form
                                t-if="state.filtersOpen"
                                class="o_lqa_retailers_publisher_filters"
                                t-on-submit.prevent="applyProductFilters"
                            >
                                <label>
                                    <span>Marca</span>
                                    <input type="text" t-model="state.filters.brand"/>
                                </label>
                                <label>
                                    <span>Categoria</span>
                                    <input type="text" t-model="state.filters.categoryId"/>
                                </label>
                                <label>
                                    <span>Precio minimo</span>
                                    <input type="number" min="0" t-model="state.filters.minPrice"/>
                                </label>
                                <label>
                                    <span>Precio maximo</span>
                                    <input type="number" min="0" t-model="state.filters.maxPrice"/>
                                </label>
                                <label>
                                    <span>Stock minimo</span>
                                    <input type="number" min="0" t-model="state.filters.minStock"/>
                                </label>
                                <label>
                                    <span>Stock maximo</span>
                                    <input type="number" min="0" t-model="state.filters.maxStock"/>
                                </label>
                                <label>
                                    <span>Visitas minimas</span>
                                    <input type="number" min="0" t-model="state.filters.minVisits"/>
                                </label>
                                <label>
                                    <span>Visitas maximas</span>
                                    <input type="number" min="0" t-model="state.filters.maxVisits"/>
                                </label>
                                <label>
                                    <span>Ordenes minimas</span>
                                    <input type="number" min="0" t-model="state.filters.minOrders"/>
                                </label>
                                <label>
                                    <span>Ordenes maximas</span>
                                    <input type="number" min="0" t-model="state.filters.maxOrders"/>
                                </label>
                                <label>
                                    <span>Ordenar por</span>
                                    <select class="form-select" t-model="state.filters.sortBy">
                                        <option value="">Predeterminado</option>
                                        <option value="price">Precio</option>
                                        <option value="stock">Stock</option>
                                        <option value="visits">Visitas</option>
                                        <option value="orders">Ordenes</option>
                                    </select>
                                </label>
                                <label>
                                    <span>Direccion</span>
                                    <select class="form-select" t-model="state.filters.sortOrder">
                                        <option value="asc">Ascendente</option>
                                        <option value="desc">Descendente</option>
                                    </select>
                                </label>
                                <div class="o_lqa_retailers_publisher_filters__actions">
                                    <button
                                        type="button"
                                        class="btn btn-secondary"
                                        t-on-click="clearProductFilters"
                                    >
                                        Limpiar
                                    </button>
                                    <button type="submit" class="btn btn-primary">
                                        Aplicar
                                    </button>
                                </div>
                            </form>

                            <div class="o_lqa_retailers_publisher_table_head">
                                <label>
                                    <input
                                        type="checkbox"
                                        t-att-checked="allCurrentProductsSelected"
                                        t-att-disabled="!selectableProducts.length"
                                        t-on-change="toggleCurrentPage"
                                    />
                                    <span>Seleccionar pagina</span>
                                </label>
                                <div class="o_lqa_retailers_publisher_pager">
                                    <select
                                        class="form-select"
                                        t-model="state.filters.limit"
                                        t-on-change="applyProductFilters"
                                    >
                                        <option value="20">20 por pagina</option>
                                        <option value="50">50 por pagina</option>
                                        <option value="100">100 por pagina</option>
                                    </select>
                                    <button
                                        type="button"
                                        class="btn btn-secondary"
                                        t-att-disabled="!state.pagination.has_previous || state.loadingProducts"
                                        t-on-click="previousProductsPage"
                                    >
                                        Anterior
                                    </button>
                                    <span>
                                        Pagina
                                        <t t-esc="state.pagination.page || 1"/>
                                        de
                                        <t t-esc="state.pagination.total_pages || 1"/>
                                    </span>
                                    <button
                                        type="button"
                                        class="btn btn-secondary"
                                        t-att-disabled="!state.pagination.has_next || state.loadingProducts"
                                        t-on-click="nextProductsPage"
                                    >
                                        Siguiente
                                    </button>
                                </div>
                            </div>

                            <div
                                t-if="state.loadingProducts"
                                class="o_lqa_retailers_publisher_empty"
                            >
                                Cargando productos...
                            </div>
                            <div
                                t-elif="!state.products.length"
                                class="o_lqa_retailers_publisher_empty"
                            >
                                No hay productos para mostrar.
                            </div>
                            <div t-else="" class="o_lqa_retailers_publisher_table_wrap">
                                <table>
                                    <thead>
                                        <tr>
                                            <th class="is-selection"/>
                                            <th>Producto</th>
                                            <th>MLA / SKU</th>
                                            <th>Marca</th>
                                            <th>Precio</th>
                                            <th>Stock</th>
                                            <th>Visitas</th>
                                            <th>Ordenes</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr
                                            t-foreach="state.products"
                                            t-as="product"
                                            t-key="product.delete_id || product.product_id + '-' + product.seller_sku"
                                            t-att-class="isProductSelected(product) ? 'is-selected' : ''"
                                        >
                                            <td class="is-selection">
                                                <input
                                                    type="checkbox"
                                                    t-att-checked="isProductSelected(product)"
                                                    t-att-disabled="!product.delete_id"
                                                    t-on-change="() => this.toggleProduct(product)"
                                                />
                                            </td>
                                            <td>
                                                <div class="o_lqa_retailers_publisher_product">
                                                    <img
                                                        t-if="product.image"
                                                        t-att-src="product.image"
                                                        t-att-alt="product.title"
                                                    />
                                                    <div>
                                                        <strong t-esc="product.title"/>
                                                        <small t-esc="product.category_id || '-'"/>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <a
                                                    t-if="productUrl(product)"
                                                    t-att-href="productUrl(product)"
                                                    target="_blank"
                                                    rel="noopener noreferrer"
                                                    t-esc="product.product_id"
                                                />
                                                <strong t-else="" t-esc="product.product_id || '-'"/>
                                                <small t-esc="product.seller_sku || '-'"/>
                                            </td>
                                            <td t-esc="product.brand || '-'"/>
                                            <td t-esc="formatCurrency(product.price)"/>
                                            <td t-esc="formatNumber(product.stock)"/>
                                            <td t-esc="formatNumber(product.visits)"/>
                                            <td t-esc="formatNumber(product.orders)"/>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </t>
                </section>
            </section>

            <div class="o_lqa_modal_backdrop" t-if="state.confirmDelete">
                <div class="o_lqa_retailers_publisher_modal">
                    <h2>Eliminar productos</h2>
                    <p>
                        Vas a eliminar
                        <strong t-esc="formatNumber(selectedProductIds.length)"/>
                        productos de
                        <strong t-esc="selectedFolder.name"/>.
                    </p>
                    <div class="o_lqa_retailers_publisher_modal__actions">
                        <button
                            type="button"
                            class="btn btn-secondary"
                            t-att-disabled="state.deletingProducts"
                            t-on-click="closeDeleteConfirmation"
                        >
                            Cancelar
                        </button>
                        <button
                            type="button"
                            class="btn btn-danger"
                            t-att-disabled="state.deletingProducts"
                            t-on-click="confirmDeleteProducts"
                        >
                            Eliminar productos
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
