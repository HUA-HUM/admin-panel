<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lqa_admin_panel.MercadolibreSelections">
        <div class="o_lqa_meli_selections_page">
            <header class="o_lqa_meli_selections_page__header">
                <div>
                    <p>MercadoLibre / Catalogo</p>
                    <h1>Selecciones</h1>
                    <span>Carpetas guardadas con publicaciones seleccionadas del catalogo.</span>
                </div>
                <button
                    type="button"
                    class="btn btn-secondary"
                    t-att-disabled="state.loadingFolders"
                    t-on-click="loadFolders"
                >
                    <i class="fa fa-refresh"/>
                    Actualizar
                </button>
            </header>

            <section class="o_lqa_meli_selection_layout">
                <aside class="o_lqa_meli_selection_folders">
                    <div class="o_lqa_meli_selection_folders__head">
                        <h2>Carpetas</h2>
                        <span>
                            <t t-esc="formatNumber(state.folders.length)"/>
                            creadas
                        </span>
                    </div>

                    <div t-if="state.loadingFolders" class="o_lqa_meli_selection_empty">
                        Cargando carpetas...
                    </div>
                    <div t-elif="!state.folders.length" class="o_lqa_meli_selection_empty">
                        Todavia no hay carpetas. Crealas desde MercadoLibre / Catalogo / Productos.
                    </div>
                    <div t-else="" class="o_lqa_meli_folder_list">
                        <button
                            type="button"
                            t-foreach="state.folders"
                            t-as="folder"
                            t-key="folder.id"
                            t-att-class="isSelectedFolder(folder) ? 'is-active' : ''"
                            t-on-click="() => this.selectFolder(folder)"
                        >
                            <strong t-esc="folder.name"/>
                            <span>
                                <t t-esc="formatNumber(folder.productCount)"/>
                                publicaciones
                            </span>
                            <small>
                                Creada por
                                <t t-esc="folder.creatorName || folder.creatorLogin || '-'"/>
                            </small>
                        </button>
                    </div>
                </aside>

                <section class="o_lqa_meli_selection_detail">
                    <div t-if="!selectedFolder" class="o_lqa_meli_selection_empty is-large">
                        Selecciona una carpeta para ver sus publicaciones.
                    </div>

                    <t t-else="">
                        <div class="o_lqa_meli_selection_detail__head">
                            <div>
                                <p>Carpeta</p>
                                <h2 t-esc="selectedFolder.name"/>
                                <span>
                                    Creada por
                                    <strong t-esc="selectedFolder.creatorName || selectedFolder.creatorLogin || '-'"/>
                                    el
                                    <strong t-esc="formatDateTime(selectedFolder.createdAt)"/>
                                </span>
                            </div>
                            <div class="o_lqa_meli_selection_detail__actions">
                                <button
                                    type="button"
                                    class="btn btn-secondary"
                                    t-att-disabled="isExportingFolder(selectedFolder) || !selectedColumnCount"
                                    t-on-click="() => this.downloadFolderCsv(selectedFolder)"
                                >
                                    <i class="fa fa-download"/>
                                    Descargar CSV
                                </button>
                                <button
                                    t-if="selectedFolder.canDelete"
                                    type="button"
                                    class="btn btn-danger"
                                    t-on-click="() => this.openDeleteFolder(selectedFolder)"
                                >
                                    <i class="fa fa-trash-o"/>
                                    Eliminar carpeta
                                </button>
                            </div>
                        </div>

                        <div class="o_lqa_meli_selection_stats">
                            <article>
                                <small>Publicaciones</small>
                                <strong t-esc="formatNumber(selectedFolder.productCount)"/>
                            </article>
                            <article>
                                <small>Visibles</small>
                                <strong t-esc="formatNumber(state.products.length)"/>
                            </article>
                            <article>
                                <small>Ultima edicion</small>
                                <strong t-esc="formatDateTime(selectedFolder.updatedAt)"/>
                            </article>
                        </div>

                        <section class="o_lqa_meli_csv_columns">
                            <div class="o_lqa_meli_csv_columns__head">
                                <div>
                                    <h3>Columnas del CSV</h3>
                                    <span>
                                        <t t-esc="formatNumber(selectedColumnCount)"/>
                                        seleccionadas
                                    </span>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-secondary" t-on-click="selectDefaultColumns">
                                        Basicas
                                    </button>
                                    <button type="button" class="btn btn-secondary" t-on-click="selectAllColumns">
                                        Todas
                                    </button>
                                    <button type="button" class="btn btn-secondary" t-on-click="clearColumns">
                                        Limpiar
                                    </button>
                                </div>
                            </div>
                            <div class="o_lqa_meli_csv_columns__grid">
                                <label
                                    t-foreach="csvColumns"
                                    t-as="column"
                                    t-key="column.key"
                                    t-att-class="isColumnSelected(column) ? 'is-selected' : ''"
                                >
                                    <input
                                        type="checkbox"
                                        t-att-checked="isColumnSelected(column)"
                                        t-on-change="() => this.toggleColumn(column.key)"
                                    />
                                    <span t-esc="column.label"/>
                                </label>
                            </div>
                        </section>

                        <div t-if="state.loadingProducts" class="o_lqa_meli_selection_empty">
                            Cargando publicaciones guardadas...
                        </div>
                        <div t-elif="!state.products.length" class="o_lqa_meli_selection_empty">
                            Esta carpeta todavia no tiene publicaciones.
                        </div>
                        <div t-else="" class="o_lqa_meli_selection_products">
                            <article
                                t-foreach="state.products"
                                t-as="product"
                                t-key="product.id"
                            >
                                <div class="o_lqa_meli_selection_product__media">
                                    <img
                                        t-if="product.thumbnail"
                                        t-att-src="product.thumbnail"
                                        t-att-alt="product.title || product.item_id"
                                        loading="lazy"
                                    />
                                    <img
                                        t-else=""
                                        src="/lqa_admin_panel/static/src/img/mercadolibre-logo.png?v=2"
                                        alt="Mercado Libre"
                                    />
                                    <span
                                        t-att-class="'o_lqa_meli_selection_status is-' + product.status"
                                        t-esc="statusLabel(product.status)"
                                    />
                                </div>
                                <div class="o_lqa_meli_selection_product__body">
                                    <small t-esc="product.brand || 'Sin marca'"/>
                                    <h3 t-esc="product.title || product.item_id || 'Sin titulo'"/>
                                    <span class="o_lqa_meli_selection_product__sku">
                                        <t t-esc="product.item_id || 'Sin MLA'"/>
                                        -
                                        <t t-esc="product.sku || 'Sin SKU'"/>
                                    </span>
                                    <dl>
                                        <div>
                                            <dt>Precio</dt>
                                            <dd t-esc="formatCurrency(product.price, product.currency_id)"/>
                                        </div>
                                        <div>
                                            <dt>Stock</dt>
                                            <dd t-esc="formatNumber(product.available_quantity)"/>
                                        </div>
                                        <div>
                                            <dt>Facturacion</dt>
                                            <dd t-esc="formatCurrency(product.revenue, product.currency_id)"/>
                                        </div>
                                        <div>
                                            <dt>Ordenes</dt>
                                            <dd t-esc="formatNumber(product.orders_count)"/>
                                        </div>
                                        <div>
                                            <dt>Visitas</dt>
                                            <dd t-esc="formatNumber(product.total_visits)"/>
                                        </div>
                                        <div>
                                            <dt>Conversion</dt>
                                            <dd t-esc="formatPercent(product.order_conversion_rate)"/>
                                        </div>
                                    </dl>
                                    <a
                                        t-if="product.permalink"
                                        t-att-href="product.permalink"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                    >
                                        Ver publicacion
                                    </a>
                                </div>
                            </article>
                        </div>
                    </t>
                </section>
            </section>

            <div class="o_lqa_modal_backdrop" t-if="state.deletingFolder">
                <div class="o_lqa_meli_delete_modal">
                    <h2>Eliminar carpeta</h2>
                    <p>
                        Vas a eliminar
                        <strong t-esc="state.deletingFolder.name"/>.
                        Tambien se van a eliminar sus publicaciones guardadas.
                    </p>
                    <div class="o_lqa_meli_delete_modal__actions">
                        <button type="button" class="btn btn-secondary" t-on-click="closeDeleteFolder">
                            Cancelar
                        </button>
                        <button type="button" class="btn btn-danger" t-on-click="confirmDeleteFolder">
                            Eliminar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
