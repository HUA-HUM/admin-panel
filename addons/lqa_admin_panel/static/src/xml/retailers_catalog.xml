<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lqa_admin_panel.RetailersCatalog">
        <div class="o_lqa_retailers_catalog">
            <header class="o_lqa_retailers_catalog__header">
                <div>
                    <p>Retailers / Marketplaces</p>
                    <h1>Catálogo</h1>
                    <span>Estado de productos publicados por marketplace.</span>
                </div>
                <button
                    type="button"
                    class="btn btn-secondary"
                    t-att-disabled="state.loadingCatalog || state.searching"
                    t-on-click="refreshCurrent"
                >
                    <i class="fa fa-refresh"/>
                    Actualizar
                </button>
            </header>

            <form
                class="o_lqa_retailers_catalog_search"
                t-on-submit.prevent="searchSku"
            >
                <label>
                    <i class="fa fa-search"/>
                    <input
                        type="search"
                        placeholder="Buscar seller SKU"
                        t-model="state.query"
                    />
                </label>
                <button
                    type="submit"
                    class="btn btn-primary"
                    t-att-disabled="state.searching"
                >
                    Buscar
                </button>
                <button
                    t-if="showingSearch"
                    type="button"
                    class="btn btn-secondary"
                    t-on-click="clearSearch"
                >
                    Ver catálogo
                </button>
            </form>

            <div class="o_lqa_retailers_catalog_toolbar">
                <div>
                    <h2 t-if="showingSearch">Resultado del SKU</h2>
                    <h2 t-else="">Todos los productos</h2>
                    <span t-if="showingSearch" t-esc="state.searchResult.seller_sku"/>
                    <span t-else="">
                        <t t-esc="formatNumber(state.catalog.pagination.count || 0)"/>
                        visibles de
                        <t t-esc="formatNumber(state.catalog.pagination.total || 0)"/>
                    </span>
                </div>
                <div t-if="!showingSearch" class="o_lqa_retailers_catalog_pager">
                    <select
                        class="form-select"
                        t-model="state.filters.limit"
                        t-on-change="changeLimit"
                    >
                        <option value="10">10 por página</option>
                        <option value="25">25 por página</option>
                        <option value="50">50 por página</option>
                    </select>
                    <button
                        type="button"
                        class="btn btn-secondary"
                        t-att-disabled="!state.catalog.pagination.has_previous || state.loadingCatalog"
                        t-on-click="previousPage"
                    >
                        Anterior
                    </button>
                    <span>
                        Página
                        <t t-esc="state.catalog.pagination.page || 1"/>
                        de
                        <t t-esc="state.catalog.pagination.total_pages || 1"/>
                    </span>
                    <button
                        type="button"
                        class="btn btn-secondary"
                        t-att-disabled="!state.catalog.pagination.has_next || state.loadingCatalog"
                        t-on-click="nextPage"
                    >
                        Siguiente
                    </button>
                </div>
            </div>

            <div
                t-if="state.loadingCatalog &amp;&amp; !showingSearch"
                class="o_lqa_retailers_catalog_empty"
            >
                Cargando catálogo...
            </div>
            <div t-elif="state.searching" class="o_lqa_retailers_catalog_empty">
                Buscando SKU...
            </div>
            <div
                t-elif="!displayedItems.length"
                class="o_lqa_retailers_catalog_empty"
            >
                No hay productos para mostrar.
            </div>
            <section t-else="" class="o_lqa_retailers_catalog_list">
                <article
                    class="o_lqa_retailers_catalog_product"
                    t-foreach="displayedItems"
                    t-as="product"
                    t-key="product.seller_sku"
                >
                    <div class="o_lqa_retailers_catalog_product__head">
                        <div>
                            <small>Seller SKU</small>
                            <h3 t-esc="product.seller_sku || '-'"/>
                        </div>
                        <div class="o_lqa_retailers_catalog_channels">
                            <span
                                t-foreach="product.marketplaces"
                                t-as="marketplace"
                                t-key="marketplace"
                                t-esc="marketplaceLabel(marketplace)"
                            />
                        </div>
                    </div>

                    <div
                        t-if="!product.items.length"
                        class="o_lqa_retailers_catalog_empty is-compact"
                    >
                        Sin detalle por marketplace.
                    </div>
                    <div t-else="" class="o_lqa_retailers_catalog_table_wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Marketplace</th>
                                    <th>Marketplace SKU</th>
                                    <th>ID externo</th>
                                    <th>Precio</th>
                                    <th>Stock</th>
                                    <th>Estado</th>
                                    <th>Activo</th>
                                    <th>Última actualización</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr
                                    t-foreach="product.items"
                                    t-as="item"
                                    t-key="item.marketplace + '-' + item.marketplace_sku + '-' + item.external_id"
                                >
                                    <td>
                                        <strong t-esc="marketplaceLabel(item.marketplace)"/>
                                    </td>
                                    <td t-esc="item.marketplace_sku || '-'"/>
                                    <td>
                                        <span
                                            class="o_lqa_retailers_catalog_external"
                                            t-esc="item.external_id || '-'"
                                        />
                                    </td>
                                    <td t-esc="formatCurrency(item.price)"/>
                                    <td t-esc="formatNumber(item.stock)"/>
                                    <td>
                                        <span
                                            t-att-class="'o_lqa_retailers_catalog_status ' + statusClass(item.status)"
                                            t-esc="statusLabel(item.status)"
                                        />
                                    </td>
                                    <td>
                                        <span
                                            t-att-class="item.is_active
                                                ? 'o_lqa_retailers_catalog_active is-active'
                                                : 'o_lqa_retailers_catalog_active'"
                                        >
                                            <i
                                                t-att-class="item.is_active
                                                    ? 'fa fa-check'
                                                    : 'fa fa-minus'"
                                            />
                                            <t t-esc="item.is_active ? 'Sí' : 'No'"/>
                                        </span>
                                    </td>
                                    <td t-esc="formatDateTime(item.updated_at || item.last_seen_at)"/>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </article>
            </section>
        </div>
    </t>
</templates>
