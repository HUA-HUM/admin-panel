<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lqa_admin_panel.MercadolibreDeleter">
        <div class="o_lqa_deleter">
            <header class="o_lqa_deleter__header">
                <div>
                    <p>MercadoLibre</p>
                    <h1>Eliminador de publicaciones</h1>
                    <span>
                        Carga MLAs manualmente o desde un CSV y conserva el historial de ejecuciones.
                    </span>
                </div>
                <img
                    src="/lqa_admin_panel/static/src/img/mercadolibre-logo.png?v=2"
                    alt="Mercado Libre"
                />
            </header>

            <section class="o_lqa_deleter__workspace">
                <div class="o_lqa_deleter__input">
                    <div class="o_lqa_deleter__section_heading">
                        <div>
                            <h2>Publicaciones a eliminar</h2>
                            <span>Una por linea o separadas por coma.</span>
                        </div>
                        <strong>
                            <t t-esc="state.parsedIds.length"/>
                            MLAs validos
                        </strong>
                    </div>

                    <textarea
                        class="form-control"
                        rows="12"
                        placeholder="MLA1457225727&#10;MLA1488457181&#10;MLA1504439295"
                        t-att-value="state.idsText"
                        t-on-input="onIdsInput"
                    />

                    <div class="o_lqa_deleter__import">
                        <label class="btn btn-secondary">
                            <i class="fa fa-upload"/>
                            Importar CSV
                            <input
                                type="file"
                                accept=".csv,text/csv,text/plain"
                                t-on-change="onCsvSelected"
                            />
                        </label>
                        <span t-if="state.csvName" t-esc="state.csvName"/>
                        <span t-else="">Se busca cualquier valor con formato MLA + numeros.</span>
                    </div>

                    <label class="o_lqa_deleter__reason">
                        <span>Motivo del lote *</span>
                        <textarea
                            class="form-control"
                            rows="3"
                            placeholder="Ej: publicaciones duplicadas, catálogo viejo, limpieza por campaña..."
                            t-model="state.reason"
                        ></textarea>
                        <small>Se guarda en el historial del lote.</small>
                    </label>

                    <div class="o_lqa_deleter__controls">
                        <label>
                            <span>App key</span>
                            <input
                                type="text"
                                class="form-control"
                                t-model="state.appKey"
                            />
                        </label>
                        <div>
                            <button
                                type="button"
                                class="btn btn-secondary"
                                t-on-click="clearIds"
                            >
                                Limpiar
                            </button>
                            <button
                                type="button"
                                class="btn btn-danger"
                                t-att-disabled="!canSubmitDeletion"
                                t-on-click="openConfirmation"
                            >
                                <i class="fa fa-trash"/>
                                Eliminar publicaciones
                            </button>
                        </div>
                    </div>
                </div>

                <aside class="o_lqa_deleter__summary">
                    <h2>Antes de ejecutar</h2>
                    <ul>
                        <li>Los MLAs duplicados se envian una sola vez.</li>
                        <li>Los valores con formato invalido se ignoran.</li>
                        <li>Cada ejecucion queda registrada con usuario y fecha.</li>
                        <li>El motivo queda guardado en el lote para auditoria.</li>
                        <li>La accion requiere confirmacion final.</li>
                    </ul>
                    <div>
                        <span>Lote actual</span>
                        <strong t-esc="state.parsedIds.length"/>
                        <small>publicaciones</small>
                    </div>
                </aside>
            </section>

            <section class="o_lqa_deleter_history">
                <div class="o_lqa_deleter__section_heading">
                    <div>
                        <h2>Historial de eliminaciones</h2>
                        <span>Ultimos lotes procesados y detalle de cada MLA.</span>
                    </div>
                    <button
                        type="button"
                        class="btn btn-secondary"
                        t-on-click="loadHistory"
                    >
                        <i class="fa fa-refresh"/>
                        Actualizar
                    </button>
                </div>

                <div class="o_lqa_deleter_history_search">
                    <label>
                        <i class="fa fa-search"/>
                        <input
                            type="search"
                            class="form-control"
                            placeholder="Buscar MLA, motivo, usuario o lote"
                            t-att-value="state.historySearch"
                            t-on-input="onHistorySearchInput"
                        />
                    </label>
                    <button
                        type="button"
                        class="btn btn-secondary"
                        t-att-disabled="!state.historySearch"
                        t-on-click="clearHistorySearch"
                    >
                        Limpiar
                    </button>
                    <span t-if="normalizedHistorySearch">
                        <t t-esc="historySearchResultsCount"/>
                        lotes encontrados
                    </span>
                </div>

                <div class="o_lqa_deleter__loading" t-if="state.loadingHistory">
                    Cargando historial...
                </div>
                <div class="o_lqa_deleter__empty" t-elif="!state.history.length">
                    Todavia no hay eliminaciones registradas.
                </div>
                <div class="o_lqa_deleter__empty" t-elif="!filteredHistory.length">
                    No hay lotes que coincidan con la busqueda.
                </div>
                <div class="o_lqa_deleter_batches" t-else="">
                    <details
                        class="o_lqa_deleter_batch"
                        t-foreach="filteredHistory"
                        t-as="batch"
                        t-key="batch.id"
                    >
                        <summary>
                            <div>
                                <span
                                    t-att-class="'o_lqa_deleter_status is-' + batch.status"
                                    t-esc="statusLabel(batch.status)"
                                />
                                <strong>
                                    Lote #<t t-esc="batch.id"/>
                                </strong>
                                <span t-esc="formatDateTime(batch.date)"/>
                            </div>
                            <div>
                                <span>
                                    <b t-esc="batch.deleted_count"/>
                                    eliminados
                                </span>
                                <span t-if="batch.failed_count">
                                    <b t-esc="batch.failed_count"/>
                                    fallidos
                                </span>
                                <span t-esc="batch.user"/>
                            </div>
                        </summary>

                        <t t-set="visibleLines" t-value="batchLines(batch)"/>
                        <section class="o_lqa_deleter_batch__reason">
                            <div class="o_lqa_deleter_batch__reason_head">
                                <div>
                                    <strong>Motivo del lote</strong>
                                    <span>Registro manual editable para auditoria.</span>
                                </div>
                                <button
                                    t-if="!isEditingBatchReason(batch)"
                                    type="button"
                                    class="btn btn-secondary"
                                    t-on-click="() => this.startBatchReasonEdit(batch)"
                                >
                                    <i class="fa fa-pencil"/>
                                    <t t-if="batch.reason">Editar motivo</t>
                                    <t t-else="">Registrar motivo</t>
                                </button>
                            </div>
                            <div
                                t-if="isEditingBatchReason(batch)"
                                class="o_lqa_deleter_batch__reason_editor"
                            >
                                <textarea
                                    class="form-control"
                                    rows="3"
                                    placeholder="Escribi el motivo de este lote..."
                                    t-att-value="batchReasonDraft(batch)"
                                    t-on-input="(event) => this.onBatchReasonInput(batch, event)"
                                ></textarea>
                                <div>
                                    <button
                                        type="button"
                                        class="btn btn-secondary"
                                        t-att-disabled="isSavingBatchReason(batch)"
                                        t-on-click="() => this.cancelBatchReasonEdit(batch)"
                                    >
                                        Cancelar
                                    </button>
                                    <button
                                        type="button"
                                        class="btn btn-primary"
                                        t-att-disabled="isSavingBatchReason(batch)"
                                        t-on-click="() => this.saveBatchReason(batch)"
                                    >
                                        <t t-if="isSavingBatchReason(batch)">Guardando...</t>
                                        <t t-else="">Guardar motivo</t>
                                    </button>
                                </div>
                            </div>
                            <p t-elif="batch.reason" t-esc="batch.reason"/>
                            <p t-else="" class="is-empty">Sin motivo registrado.</p>
                        </section>
                        <p
                            t-if="batch.error_message"
                            class="o_lqa_deleter_batch__error"
                            t-esc="batch.error_message"
                        />
                        <section class="o_lqa_deleter_batch__lines">
                            <div class="o_lqa_deleter_batch__line_tools">
                                <label>
                                    <i class="fa fa-search"/>
                                    <input
                                        type="search"
                                        class="form-control"
                                        placeholder="Buscar MLA dentro de este lote"
                                        t-att-value="batchLineSearch(batch)"
                                        t-on-input="(event) => this.onBatchLineSearchInput(batch, event)"
                                    />
                                </label>
                                <button
                                    type="button"
                                    class="btn btn-secondary"
                                    t-att-disabled="!batchLineSearch(batch)"
                                    t-on-click="() => this.clearBatchLineSearch(batch)"
                                >
                                    Limpiar
                                </button>
                                <span t-esc="batchLineResultsLabel(batch)"/>
                            </div>
                            <div class="o_lqa_deleter_lines_wrap">
                                <table class="o_lqa_deleter_lines">
                                    <thead>
                                        <tr>
                                            <th>MLA</th>
                                            <th>Estado</th>
                                            <th>Detalle</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-if="!visibleLines.length">
                                            <td colspan="3" class="o_lqa_deleter_lines__empty">
                                                No hay publicaciones que coincidan con la busqueda.
                                            </td>
                                        </tr>
                                        <tr
                                            t-foreach="visibleLines"
                                            t-as="line"
                                            t-key="line.id"
                                        >
                                            <td>
                                                <strong t-esc="line.mla"/>
                                            </td>
                                            <td>
                                                <span
                                                    t-att-class="'o_lqa_deleter_line_status is-' + line.status"
                                                    t-esc="statusLabel(line.status)"
                                                />
                                            </td>
                                            <td>
                                                <span
                                                    t-if="line.message"
                                                    class="o_lqa_deleter_lines__message"
                                                    t-att-title="line.message"
                                                    t-esc="line.message"
                                                />
                                                <span t-else="" class="o_lqa_deleter_lines__muted">
                                                    Sin detalle
                                                </span>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                    </details>
                </div>
            </section>

            <div class="o_lqa_delete_modal" t-if="state.showConfirmation">
                <button
                    type="button"
                    class="o_lqa_delete_modal__backdrop"
                    aria-label="Cancelar eliminacion"
                    t-on-click="closeConfirmation"
                />
                <section role="dialog" aria-modal="true" aria-labelledby="delete-title">
                    <div class="o_lqa_delete_modal__icon">
                        <i class="fa fa-exclamation-triangle"/>
                    </div>
                    <h2 id="delete-title">Confirmar eliminacion</h2>
                    <p>
                        Se enviaran
                        <strong t-esc="state.parsedIds.length"/>
                        publicaciones a la API de eliminacion. Esta operacion no se puede deshacer desde el panel.
                    </p>
                    <p t-if="state.reason">
                        Motivo:
                        <strong t-esc="trimmedReason"/>
                    </p>
                    <div class="o_lqa_delete_modal__actions">
                        <button
                            type="button"
                            class="btn btn-secondary"
                            t-att-disabled="state.processing"
                            t-on-click="closeConfirmation"
                        >
                            Cancelar
                        </button>
                        <button
                            type="button"
                            class="btn btn-danger"
                            t-att-disabled="state.processing"
                            t-on-click="confirmDeletion"
                        >
                            <t t-if="state.processing">Procesando...</t>
                            <t t-else="">Si, eliminar</t>
                        </button>
                    </div>
                </section>
            </div>
        </div>
    </t>
</templates>
