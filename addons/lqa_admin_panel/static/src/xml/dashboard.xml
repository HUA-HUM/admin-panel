<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lqa_admin_panel.Dashboard">
        <div class="o_lqa_dashboard">
            <header class="o_lqa_dashboard__header">
                <div>
                    <p class="o_lqa_dashboard__eyebrow">
                        <t t-esc="state.selectedModuleCode ? 'Panel Comercial / Dashboard' : 'Panel Dashboard'"/>
                    </p>
                    <h1 t-esc="dashboardTitle"/>
                    <p class="o_lqa_dashboard__subtitle" t-esc="dashboardSubtitle"/>
                </div>
            </header>

            <div class="o_lqa_dashboard__loading" t-if="state.loading">
                <span class="o_lqa_inline_spinner" aria-hidden="true"/>
                <strong>Cargando panel</strong>
            </div>

            <t t-else="">
                <t t-if="!state.selectedModuleCode">
                    <section class="o_lqa_dashboard_summary">
                        <div class="o_lqa_dashboard_summary__item">
                            <span class="is-favorites">
                                <i class="fa fa-star"/>
                            </span>
                            <div>
                                <small>Favoritos</small>
                                <strong t-esc="state.favorites.length"/>
                                <p>Accesos personales</p>
                            </div>
                        </div>
                        <div class="o_lqa_dashboard_summary__item">
                            <span class="is-sections">
                                <i class="fa fa-th-large"/>
                            </span>
                            <div>
                                <small>Herramientas</small>
                                <strong t-esc="availableSectionsCount"/>
                                <p>Secciones disponibles</p>
                            </div>
                        </div>
                        <div class="o_lqa_dashboard_summary__item">
                            <span class="is-modules">
                                <i class="fa fa-cubes"/>
                            </span>
                            <div>
                                <small>Módulos</small>
                                <strong t-esc="activeModulesCount"/>
                                <p>Áreas activas</p>
                            </div>
                        </div>
                    </section>

                    <section class="o_lqa_dashboard_favorites">
                        <div class="o_lqa_dashboard_favorites__head">
                            <div>
                                <p>Espacio personal</p>
                                <h2>Accesos favoritos</h2>
                            </div>
                            <span>
                                <i class="fa fa-star"/>
                                <t t-esc="state.favorites.length"/>
                            </span>
                        </div>
                        <div
                            t-if="!state.favorites.length"
                            class="o_lqa_dashboard_favorites__empty"
                        >
                            <span>
                                <i class="fa fa-star-o"/>
                            </span>
                            <strong>No hay secciones favoritas</strong>
                        </div>
                        <div t-else="" class="o_lqa_dashboard_favorites__grid">
                            <button
                                type="button"
                                t-foreach="state.favorites"
                                t-as="favorite"
                                t-key="favorite.menu_id"
                                t-on-click="() => this.openFavorite(favorite)"
                            >
                                <span class="o_lqa_dashboard_favorite_icon">
                                    <i t-att-class="favoriteIcon(favorite)"/>
                                </span>
                                <span>
                                    <small t-esc="favorite.path || 'Panel Comercial'"/>
                                    <strong t-esc="favorite.name"/>
                                </span>
                                <i class="fa fa-arrow-right"/>
                            </button>
                        </div>
                    </section>
                </t>

                <div
                    t-if="state.selectedModuleCode"
                    class="o_lqa_dashboard__grid"
                >
                    <section
                        class="o_lqa_module"
                        t-foreach="state.modules"
                        t-as="module"
                        t-key="module.code"
                    >
                        <div class="o_lqa_module__body">
                            <div class="o_lqa_module__title">
                                <div>
                                    <p>Resumen</p>
                                    <h2 t-esc="module.name"/>
                                </div>
                            </div>
                            <p class="o_lqa_module__description" t-esc="module.description"/>

                            <div class="o_lqa_metrics" t-if="module.metrics.length">
                                <div
                                    class="o_lqa_metric"
                                    t-foreach="module.metrics"
                                    t-as="metric"
                                    t-key="metric.label"
                                >
                                    <strong t-esc="metric.value"/>
                                    <span t-esc="metric.label"/>
                                </div>
                            </div>
                        </div>

                        <div class="o_lqa_sections">
                            <button
                                type="button"
                                class="o_lqa_section"
                                t-foreach="module.sections"
                                t-as="section"
                                t-key="section.code"
                                t-on-click="() => this.openSection(section)"
                            >
                                <div>
                                    <span t-att-class="'o_lqa_section__state is-' + section.status"/>
                                    <strong t-esc="section.name"/>
                                    <p t-esc="section.description"/>
                                </div>
                                <small t-if="section.badge" t-esc="section.badge"/>
                            </button>
                        </div>
                    </section>
                </div>
            </t>
        </div>
    </t>
</templates>
