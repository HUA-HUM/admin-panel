<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lqa_admin_panel.Accounting">
        <div t-att-class="'o_lqa_accounting ' + (isArcaBilling ? 'is-comprobantes-page' : '')">
            <header class="o_lqa_accounting__header">
                <div>
                    <p>Administracion</p>
                    <h1 t-esc="pageTitle"/>
                    <span t-esc="pageSubtitle"/>
                </div>
                <button
                    t-if="isWorkspace"
                    type="button"
                    class="o_lqa_accounting__ghost"
                    t-on-click="openBack"
                >
                    <i class="fa fa-arrow-left"/>
                    Volver
                </button>
            </header>

            <section t-if="isDashboard" class="o_lqa_accounting__summary">
                <article>
                    <small>Area</small>
                    <strong>Contable</strong>
                    <span>Administracion</span>
                </article>
                <article>
                    <small>Integracion</small>
                    <strong>Xubio</strong>
                    <span>Clientes y comprobantes</span>
                </article>
                <article>
                    <small>Secciones</small>
                    <strong>2</strong>
                    <span>Clientes y comprobantes</span>
                </article>
            </section>

            <section t-if="isDashboard" class="o_lqa_accounting__modules">
                <article class="o_lqa_accounting__xubio_module">
                    <span class="o_lqa_accounting__brand_icon">
                        <img src="/lqa_admin_panel/static/src/img/xubio-logo.png" alt="Xubio"/>
                    </span>
                    <div class="o_lqa_accounting__xubio_module_body">
                        <small>Modulo Xubio</small>
                        <strong>Xubio</strong>
                        <p>Clientes fiscales y comprobantes sincronizados desde la operacion contable.</p>
                        <div class="o_lqa_accounting__xubio_actions">
                            <button type="button" t-on-click="openClients">
                                <i class="fa fa-users"/>
                                Clientes
                            </button>
                            <button type="button" t-on-click="openArcaBilling">
                                <i class="fa fa-file-text-o"/>
                                Comprobantes
                            </button>
                        </div>
                    </div>
                    <button type="button" class="o_lqa_accounting__xubio_open" t-on-click="openXubio">
                        Ver modulo
                        <i class="fa fa-arrow-right"/>
                    </button>
                </article>
            </section>

            <t t-if="isWorkspace">
                <t t-if="isClients">
                    <section class="o_lqa_accounting__client_workspace">
                        <nav class="o_lqa_accounting__client_tabs" role="tablist">
                            <button
                                type="button"
                                t-att-class="'o_lqa_accounting__client_tab ' + (state.clients.activeTab === 'fiscal' ? 'is-active' : '')"
                                t-on-click="() => this.setClientTab('fiscal')"
                            >
                                <span>1</span>
                                <strong>Clientes CUIT/CUIL</strong>
                                <small>Alta fiscal desde TLQV</small>
                            </button>
                            <button
                                type="button"
                                t-att-class="'o_lqa_accounting__client_tab ' + (state.clients.activeTab === 'consumer' ? 'is-active' : '')"
                                t-on-click="() => this.setClientTab('consumer')"
                            >
                                <span>2</span>
                                <strong>Consumidor final</strong>
                                <small>DNI e issues fiscales</small>
                            </button>
                            <button
                                type="button"
                                t-att-class="'o_lqa_accounting__client_tab ' + (state.clients.activeTab === 'records' ? 'is-active' : '')"
                                t-on-click="() => this.setClientTab('records')"
                            >
                                <span>3</span>
                                <strong>Registros</strong>
                                <small>Lotes y resultados</small>
                            </button>
                        </nav>

                        <article t-if="state.clients.activeTab === 'fiscal'" class="o_lqa_accounting__workflow_section o_lqa_accounting__tab_panel is-primary">
                            <div class="o_lqa_accounting__section_head">
                                <span class="o_lqa_accounting__section_index">1</span>
                                <div>
                                    <p>Alta fiscal</p>
                                    <h2>Clientes con CUIT o CUIL</h2>
                                    <span>
                                        Para empresas, responsables inscriptos o compradores con datos fiscales validos.
                                        El alta se hace siempre desde un codigo TLQV porque desde ahi recuperamos la orden y la informacion del cliente.
                                    </span>
                                </div>
                            </div>

                            <section class="o_lqa_accounting__panel is-emphasis is-client-create">
                                <div class="o_lqa_accounting__panel_head">
                                    <div>
                                        <h2>Crear cliente desde TLQV</h2>
                                        <p>Subi un CSV con codigos TLQV o pega varios TLQV manualmente, uno por linea.</p>
                                    </div>
                                    <span>Invoice API</span>
                                </div>
                                <div class="o_lqa_accounting__form">
                                    <label>
                                        CSV de TLQV
                                        <input
                                            type="file"
                                            accept=".csv,text/csv"
                                            class="form-control"
                                            t-on-change="onClientFileChange"
                                        />
                                    </label>
                                    <div t-if="state.clients.fileName" class="o_lqa_accounting__file">
                                        <i class="fa fa-paperclip"/>
                                        <span t-esc="state.clients.fileName"/>
                                    </div>
                                    <label>
                                        TLQV manuales
                                        <textarea
                                            rows="7"
                                            placeholder="TLQV-7734&#10;TLQV-13414"
                                            t-model="state.clients.manualInput"
                                        />
                                    </label>
                                    <button
                                        type="button"
                                        class="o_lqa_accounting__primary"
                                        t-att-disabled="state.clients.running ? true : undefined"
                                        t-on-click="runClientCreation"
                                    >
                                        <i t-att-class="state.clients.running ? 'fa fa-spinner fa-spin' : 'fa fa-play'"/>
                                        <t t-if="state.clients.running">Procesando</t>
                                        <t t-else="">Crear clientes fiscales</t>
                                    </button>
                                </div>
                            </section>
                        </article>

                        <article t-if="state.clients.activeTab === 'consumer'" class="o_lqa_accounting__workflow_section o_lqa_accounting__tab_panel">
                            <div class="o_lqa_accounting__section_head">
                                <span class="o_lqa_accounting__section_index">2</span>
                                <div>
                                    <p>Consumidor final</p>
                                    <h2>Alta con DNI cuando no hay datos fiscales</h2>
                                    <span>
                                        Usalo para crear consumidor final desde un TLQV puntual o desde clientes que fallaron por CUIT/CUIL.
                                        La tabla de issues trae esos casos desde Madre para convertirlos rapido.
                                    </span>
                                </div>
                            </div>

                            <section class="o_lqa_accounting__panel is-client-issues">
                                <div class="o_lqa_accounting__panel_head">
                                    <div>
                                        <h2>Consumidor final con DNI</h2>
                                        <p>Crea por TLQV o busca clientes con error fiscal para resolverlos como consumidor final.</p>
                                    </div>
                                    <span>Issues Madre</span>
                                </div>
                                <div class="o_lqa_accounting__inline_form">
                                    <label>
                                        Crear consumidor final por TLQV
                                        <input
                                            type="text"
                                            placeholder="TLQV-7734"
                                            t-model="state.issueClients.manualTlqv"
                                        />
                                    </label>
                                    <button
                                        type="button"
                                        class="o_lqa_accounting__primary"
                                        t-att-disabled="state.issueClients.manualRunning ? true : undefined"
                                        t-on-click="createConsumerFinalManual"
                                    >
                                        <i t-att-class="state.issueClients.manualRunning ? 'fa fa-spinner fa-spin' : 'fa fa-user-plus'"/>
                                        Crear consumidor final
                                    </button>
                                </div>
                                <div class="o_lqa_accounting__filters">
                                    <label>
                                        TLQV
                                        <input type="text" placeholder="TLQV-14921" t-model="state.issueClients.filters.tlqvCode"/>
                                    </label>
                                    <label>
                                        Nombre comprador
                                        <input type="text" placeholder="ARTURO GUTIERREZ" t-model="state.issueClients.filters.buyerName"/>
                                    </label>
                                    <label>
                                        Email
                                        <input type="text" placeholder="mail@test.com" t-model="state.issueClients.filters.email"/>
                                    </label>
                                    <label>
                                        Documento digitos
                                        <input type="text" placeholder="20111111114" t-model="state.issueClients.filters.documentoNroDigits"/>
                                    </label>
                                    <label>
                                        Limite
                                        <select t-model="state.issueClients.filters.limit">
                                            <option value="25">25</option>
                                            <option value="50">50</option>
                                            <option value="100">100</option>
                                            <option value="200">200</option>
                                        </select>
                                    </label>
                                </div>
                                <div class="o_lqa_accounting__actions is-filter-actions">
                                    <button type="button" class="o_lqa_accounting__ghost" t-on-click="clearClientIssueFilters">
                                        Limpiar
                                    </button>
                                    <button
                                        type="button"
                                        class="o_lqa_accounting__primary"
                                        t-att-disabled="state.issueClients.loading ? true : undefined"
                                        t-on-click="() => this.searchClientIssues()"
                                    >
                                        <i t-att-class="state.issueClients.loading ? 'fa fa-spinner fa-spin' : 'fa fa-search'"/>
                                        Buscar issues
                                    </button>
                                </div>
                                <div class="o_lqa_accounting__panel_head is-subtle">
                                    <div>
                                        <h2>Clientes con issue</h2>
                                        <p>
                                            <t t-esc="formatNumber(state.issueClients.result.pagination.count)"/>
                                            visibles de
                                            <t t-esc="formatNumber(state.issueClients.result.pagination.total)"/>
                                        </p>
                                    </div>
                                    <div class="o_lqa_accounting__pagination">
                                        <button
                                            type="button"
                                            t-att-disabled="!state.issueClients.result.pagination.has_previous ? true : undefined"
                                            t-on-click="previousClientIssuesPage"
                                        >
                                            Anterior
                                        </button>
                                        <span>Pagina <t t-esc="state.issueClients.result.pagination.page"/></span>
                                        <button
                                            type="button"
                                            t-att-disabled="!state.issueClients.result.pagination.has_next ? true : undefined"
                                            t-on-click="nextClientIssuesPage"
                                        >
                                            Siguiente
                                        </button>
                                    </div>
                                </div>
                                <div t-if="state.issueClients.result.items.length" class="o_lqa_accounting__table_wrap">
                                    <table class="o_lqa_accounting__table">
                                        <thead>
                                            <tr>
                                                <th>TLQV</th>
                                                <th>Comprador</th>
                                                <th>Documento</th>
                                                <th>Estado</th>
                                                <th>Motivo</th>
                                                <th>Mensaje</th>
                                                <th>Ultima vez</th>
                                                <th>Accion</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="state.issueClients.result.items" t-as="issue" t-key="issue.issueKey || issue.id || issue.tlqvCode">
                                                <td><strong t-esc="issue.tlqvCode || '-'"/></td>
                                                <td>
                                                    <strong t-esc="issue.buyerName || '-'"/>
                                                    <small t-esc="issue.email || ''"/>
                                                </td>
                                                <td>
                                                    <strong t-esc="issue.documentoNroDigits || issue.documentoNro || '-'"/>
                                                    <small t-esc="issue.documentoTipo || ''"/>
                                                </td>
                                                <td>
                                                    <span t-att-class="'o_lqa_accounting__pill ' + (issue.status === 'open' ? 'is-amber' : 'is-blue')" t-esc="issue.status || '-'"/>
                                                </td>
                                                <td t-esc="issue.reason || '-'"/>
                                                <td class="o_lqa_accounting__message" t-esc="issue.message || '-'"/>
                                                <td t-esc="formatDate(issue.lastSeenAt || issue.updatedAt)"/>
                                                <td>
                                                    <button
                                                        type="button"
                                                        class="o_lqa_accounting__small_primary"
                                                        t-att-disabled="state.issueClients.creating[issue.tlqvCode] ? true : undefined"
                                                        t-on-click="() => this.createConsumerFinal(issue)"
                                                    >
                                                        <i t-att-class="state.issueClients.creating[issue.tlqvCode] ? 'fa fa-spinner fa-spin' : 'fa fa-user-plus'"/>
                                                        Crear CF
                                                    </button>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <div t-else="" class="o_lqa_accounting__empty is-compact">
                                    <i class="fa fa-id-card-o"/>
                                    <strong>Sin clientes con issue</strong>
                                    <span>Busca por TLQV, nombre, email o documento para crear consumidor final.</span>
                                </div>
                            </section>
                        </article>

                        <article t-if="state.clients.activeTab === 'records'" class="o_lqa_accounting__workflow_section o_lqa_accounting__tab_panel">
                            <div class="o_lqa_accounting__section_head">
                                <span class="o_lqa_accounting__section_index">3</span>
                                <div>
                                    <p>Registros</p>
                                    <h2>Ejecuciones y resultados</h2>
                                    <span>
                                        Aca quedan los lotes procesados, quien los ejecuto y el detalle de cada TLQV enviado a Xubio.
                                    </span>
                                </div>
                                <button
                                    type="button"
                                    class="o_lqa_accounting__ghost"
                                    t-att-disabled="state.clients.loadingJobs ? true : undefined"
                                    t-on-click="() => this.loadClientJobs()"
                                >
                                    <i t-att-class="state.clients.loadingJobs ? 'fa fa-spinner fa-spin' : 'fa fa-refresh'"/>
                                    Actualizar
                                </button>
                            </div>

                            <section class="o_lqa_accounting__records_grid">
                                <article class="o_lqa_accounting__panel is-history is-client-history">
                                    <div class="o_lqa_accounting__panel_head">
                                        <div>
                                            <h2>Historial</h2>
                                            <p>Ultimos lotes procesados.</p>
                                        </div>
                                        <span t-esc="formatNumber(state.clients.jobs.length) + ' lotes'"/>
                                    </div>
                                    <div t-if="state.clients.jobs.length" class="o_lqa_accounting__jobs">
                                        <button
                                            type="button"
                                            t-foreach="state.clients.jobs"
                                            t-as="job"
                                            t-key="job.id"
                                            t-att-class="state.clients.selectedJob &amp;&amp; state.clients.selectedJob.id === job.id ? 'is-active' : ''"
                                            t-on-click="() => this.selectJob(job)"
                                        >
                                            <div>
                                                <strong t-esc="job.operationType === 'consumer_final' ? 'Consumidor final con DNI' : 'Clientes CUIT/CUIL desde TLQV'"/>
                                                <small>
                                                    <t t-esc="formatDate(job.createdAt)"/>
                                                    ·
                                                    <t t-esc="job.user || '-'"/>
                                                </small>
                                            </div>
                                            <span t-att-class="'o_lqa_accounting__pill ' + stateClass(job.state)" t-esc="stateLabel(job.state)"/>
                                        </button>
                                    </div>
                                    <div t-else="" class="o_lqa_accounting__empty is-compact">
                                        <i class="fa fa-folder-open-o"/>
                                        <strong>Sin registros todavia</strong>
                                        <span>Cuando proceses clientes, los lotes van a quedar aca.</span>
                                    </div>
                                </article>

                                <article class="o_lqa_accounting__panel is-result-panel">
                                    <div class="o_lqa_accounting__panel_head">
                                        <div>
                                            <h2>Resultado del lote</h2>
                                            <p t-esc="selectedJobSummary"/>
                                        </div>
                                        <div t-if="state.clients.selectedJob" class="o_lqa_accounting__counts">
                                            <span class="is-green">
                                                <t t-esc="formatNumber(state.clients.selectedJob.successCount)"/>
                                                creados
                                            </span>
                                            <span class="is-amber">
                                                <t t-esc="formatNumber(state.clients.selectedJob.issueCount)"/>
                                                issues
                                            </span>
                                            <span class="is-red">
                                                <t t-esc="formatNumber(state.clients.selectedJob.failedCount)"/>
                                                fallidos
                                            </span>
                                        </div>
                                    </div>
                                    <div t-if="selectedJobLines.length" class="o_lqa_accounting__table_wrap">
                                        <table class="o_lqa_accounting__table">
                                            <thead>
                                                <tr>
                                                    <th>TLQV</th>
                                                    <th>Estado</th>
                                                    <th>HTTP</th>
                                                    <th>Respuesta</th>
                                                    <th>Issues</th>
                                                    <th>Mensaje</th>
                                                    <th>Procesado</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr t-foreach="selectedJobLines" t-as="line" t-key="line.id">
                                                    <td><strong t-esc="line.tlqvCode"/></td>
                                                    <td>
                                                        <span t-att-class="'o_lqa_accounting__pill ' + stateClass(line.state)" t-esc="stateLabel(line.state)"/>
                                                    </td>
                                                    <td t-esc="line.httpStatus || '-'"/>
                                                    <td t-esc="line.responseStatus || '-'"/>
                                                    <td t-esc="formatNumber(line.issuesCount)"/>
                                                    <td class="o_lqa_accounting__message" t-esc="line.message || '-'"/>
                                                    <td t-esc="formatDate(line.processedAt)"/>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                    <div t-else="" class="o_lqa_accounting__empty">
                                        <i class="fa fa-list-alt"/>
                                        <strong>Sin resultados seleccionados</strong>
                                        <span>Procesa un lote o elegi un registro del historial.</span>
                                    </div>
                                </article>
                            </section>
                        </article>
                    </section>
                </t>

                <t t-if="isXubio">
                    <section class="o_lqa_accounting__panel o_lqa_accounting__xubio">
                        <div class="o_lqa_accounting__xubio_hero">
                            <img
                                src="/lqa_admin_panel/static/src/img/xubio-logo.png"
                                alt="Xubio"
                            />
                            <div>
                                <small>Modulo Xubio</small>
                                <h2>Xubio</h2>
                                <p>
                                    Centraliza las herramientas contables de clientes y comprobantes conectadas con Xubio.
                                </p>
                            </div>
                        </div>
                        <div class="o_lqa_accounting__xubio_grid">
                            <button type="button" t-on-click="openClients">
                                <i class="fa fa-users"/>
                                <strong>Clientes</strong>
                                <span>Issues de CUIT, altas por TLQV y conversion a consumidor final con DNI.</span>
                            </button>
                            <button type="button" t-on-click="openArcaBilling">
                                <i class="fa fa-file-text-o"/>
                                <strong>Comprobantes</strong>
                                <span>Auditoria y consulta de comprobantes sincronizados.</span>
                            </button>
                        </div>
                    </section>
                </t>

                <t t-if="isArcaBilling">
                    <section class="o_lqa_accounting__comprobante_hero">
                        <div>
                            <p>Auditoria Xubio</p>
                            <h2>Comprobantes emitidos</h2>
                            <span>
                                Consulta comprobantes sincronizados, revisa importes fiscales y descarga el respaldo PDF por TLQV.
                            </span>
                        </div>
                        <button
                            type="button"
                            class="o_lqa_accounting__ghost"
                            t-att-disabled="state.xubio.loading ? true : undefined"
                            t-on-click="() => this.searchComprobantes(state.xubio.result.pagination.offset || 0)"
                        >
                            <i t-att-class="state.xubio.loading ? 'fa fa-spinner fa-spin' : 'fa fa-refresh'"/>
                            Actualizar
                        </button>
                    </section>

                    <section class="o_lqa_accounting__panel is-comprobantes_filters">
                        <div class="o_lqa_accounting__panel_head">
                            <div>
                                <h2>Explorador de comprobantes</h2>
                                <p>Filtra por TLQV, documento, cliente, orden ML, tipo y rango de emision.</p>
                            </div>
                            <span>Madre DB</span>
                        </div>
                        <div class="o_lqa_accounting__filters">
                            <label>
                                TLQV
                                <input type="text" placeholder="TLQV-101" t-model="state.xubio.filters.tlqvCode"/>
                            </label>
                            <label>
                                Numero documento
                                <input type="text" placeholder="B-00008-00001697" t-model="state.xubio.filters.numeroDocumento"/>
                            </label>
                            <label>
                                Cliente
                                <input type="text" placeholder="30652957044" t-model="state.xubio.filters.clienteCodigo"/>
                            </label>
                            <label>
                                Orden ML
                                <input type="text" placeholder="2000016621010338" t-model="state.xubio.filters.mlOrderId"/>
                            </label>
                            <label>
                                Tipo
                                <select t-model="state.xubio.filters.documentKind">
                                    <option value="">Todos</option>
                                    <option value="INVOICE">Factura</option>
                                    <option value="CREDIT_NOTE">Nota de credito</option>
                                    <option value="DEBIT_NOTE">Nota de debito</option>
                                </select>
                            </label>
                            <label>
                                Desde
                                <input type="date" t-model="state.xubio.filters.fechaDesde"/>
                            </label>
                            <label>
                                Hasta
                                <input type="date" t-model="state.xubio.filters.fechaHasta"/>
                            </label>
                            <label>
                                Limite
                                <select t-model="state.xubio.filters.limit">
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                    <option value="100">100</option>
                                    <option value="200">200</option>
                                </select>
                            </label>
                        </div>
                        <div class="o_lqa_accounting__actions is-filter-actions">
                            <button
                                type="button"
                                class="o_lqa_accounting__ghost"
                                t-on-click="toggleXubioExportFields"
                            >
                                <i class="fa fa-columns"/>
                                Campos Excel
                                <span t-if="xubioSelectedColumnsCount" t-esc="xubioSelectedColumnsCount"/>
                            </button>
                            <button
                                type="button"
                                class="o_lqa_accounting__ghost"
                                t-att-disabled="state.xubio.exporting ? true : undefined"
                                t-on-click="exportXubioComprobantes"
                            >
                                <i t-att-class="state.xubio.exporting ? 'fa fa-spinner fa-spin' : 'fa fa-file-excel-o'"/>
                                Exportar Excel
                            </button>
                            <button type="button" class="o_lqa_accounting__ghost" t-on-click="clearComprobantesFilters">
                                Limpiar
                            </button>
                            <button
                                type="button"
                                class="o_lqa_accounting__primary"
                                t-att-disabled="state.xubio.loading ? true : undefined"
                                t-on-click="() => this.searchComprobantes()"
                            >
                                <i t-att-class="state.xubio.loading ? 'fa fa-spinner fa-spin' : 'fa fa-search'"/>
                                Buscar
                            </button>
                        </div>
                        <div t-if="state.xubio.showExportFields" class="o_lqa_accounting__export_fields">
                            <div class="o_lqa_accounting__export_head">
                                <div>
                                    <strong>Columnas del Excel</strong>
                                    <span>Selecciona que datos incluir en la descarga segun el analisis que necesites.</span>
                                </div>
                                <div>
                                    <button type="button" class="o_lqa_accounting__ghost" t-on-click="selectAllXubioExportColumns">
                                        Todas
                                    </button>
                                    <button type="button" class="o_lqa_accounting__ghost" t-on-click="resetXubioExportColumns">
                                        Recomendadas
                                    </button>
                                </div>
                            </div>
                            <div class="o_lqa_accounting__field_grid">
                                <label
                                    t-foreach="state.xubio.exportColumns"
                                    t-as="column"
                                    t-key="column.key"
                                    t-att-class="'o_lqa_accounting__field_toggle ' + (column.selected ? 'is-selected' : '')"
                                >
                                    <input
                                        type="checkbox"
                                        t-att-checked="column.selected ? true : undefined"
                                        t-on-change="() => this.toggleXubioExportColumn(column)"
                                    />
                                    <span t-esc="column.label"/>
                                </label>
                            </div>
                        </div>
                    </section>

                    <section class="o_lqa_accounting__panel is-comprobantes_table">
                        <div class="o_lqa_accounting__panel_head">
                            <div>
                                <h2>Listado de comprobantes</h2>
                                <p>
                                    <t t-esc="formatNumber(state.xubio.result.pagination.count)"/>
                                    visibles de
                                    <t t-esc="formatNumber(state.xubio.result.pagination.total)"/>
                                </p>
                            </div>
                            <div class="o_lqa_accounting__pagination">
                                <button
                                    type="button"
                                    t-att-disabled="!state.xubio.result.pagination.has_previous ? true : undefined"
                                    t-on-click="previousComprobantesPage"
                                >
                                    Anterior
                                </button>
                                <span>Pagina <t t-esc="state.xubio.result.pagination.page"/></span>
                                <button
                                    type="button"
                                    t-att-disabled="!state.xubio.result.pagination.has_next ? true : undefined"
                                    t-on-click="nextComprobantesPage"
                                >
                                    Siguiente
                                </button>
                            </div>
                        </div>
                        <div t-if="state.xubio.result.items.length" class="o_lqa_accounting__table_wrap is-comprobantes">
                            <table class="o_lqa_accounting__table is-comprobantes">
                                <thead>
                                    <tr>
                                        <th>Documento</th>
                                        <th>TLQV</th>
                                        <th>Orden ML</th>
                                        <th>Cliente</th>
                                        <th>Fechas</th>
                                        <th>Importes</th>
                                        <th>Fiscal</th>
                                        <th>Operacion</th>
                                        <th>Items</th>
                                        <th>Sync</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="state.xubio.result.items" t-as="item" t-key="item.id || item.xubioTransactionId">
                                        <td>
                                            <div class="o_lqa_accounting__doc_cell">
                                                <strong t-esc="item.numeroDocumento || '-'"/>
                                                <span t-esc="item.tipoNombre || item.documentKind || 'Comprobante'"/>
                                                <small>
                                                    Letra <t t-esc="item.letraComprobante || '-'"/>
                                                    <t t-if="item.xubioTransactionId"> · Xubio <t t-esc="item.xubioTransactionId"/></t>
                                                </small>
                                            </div>
                                        </td>
                                        <td>
                                            <strong t-esc="item.tlqvCode || '-'"/>
                                            <small t-if="item.tlqvNumber">#<t t-esc="item.tlqvNumber"/></small>
                                        </td>
                                        <td>
                                            <strong t-esc="item.mlOrderId || '-'"/>
                                            <small t-esc="item.descripcion || ''"/>
                                        </td>
                                        <td>
                                            <strong t-esc="item.clienteNombre || '-'"/>
                                            <small t-esc="item.clienteCodigo || '-'"/>
                                            <small t-if="item.clienteXubioId">ID <t t-esc="item.clienteXubioId"/></small>
                                        </td>
                                        <td>
                                            <strong>Emision</strong>
                                            <span t-esc="formatDateOnly(item.fechaEmision)"/>
                                            <strong>Venc.</strong>
                                            <span t-esc="formatDateOnly(item.fechaVencimiento)"/>
                                        </td>
                                        <td>
                                            <div class="o_lqa_accounting__amount_stack">
                                                <strong t-esc="formatCurrency(item.importeTotal)"/>
                                                <span>Gravado <t t-esc="formatCurrency(item.importeGravado)"/></span>
                                                <span>Impuestos <t t-esc="formatCurrency(item.importeImpuestos)"/></span>
                                                <small t-esc="item.monedaNombre || item.monedaCodigo || ''"/>
                                            </div>
                                        </td>
                                        <td>
                                            <span t-att-class="'o_lqa_accounting__chip ' + (item.fiscalmenteEmitido ? 'is-green' : 'is-amber')">
                                                <t t-esc="item.fiscalmenteEmitido ? 'Emitido' : 'Pendiente'"/>
                                            </span>
                                            <strong>CAE</strong>
                                            <span t-esc="item.cae || '-'"/>
                                            <small>Vto. <t t-esc="formatDateOnly(item.caeFechaVencimiento)"/></small>
                                        </td>
                                        <td>
                                            <strong t-esc="item.puntoVentaCodigo || '-'"/>
                                            <small>Deposito <t t-esc="item.depositoCodigo || '-'"/></small>
                                            <small>Circuito <t t-esc="item.circuitoContableCodigo || '-'"/></small>
                                        </td>
                                        <td>
                                            <strong><t t-esc="formatNumber(item.productItemsCount)"/> items</strong>
                                            <small t-att-title="item.productItemsSummary || ''" t-esc="item.productItemsSummary || '-'"/>
                                        </td>
                                        <td>
                                            <strong>Sync</strong>
                                            <span t-esc="formatDate(item.syncedAt)"/>
                                            <small>Creado <t t-esc="formatDate(item.createdAt)"/></small>
                                            <small>Act. <t t-esc="formatDate(item.updatedAt)"/></small>
                                        </td>
                                        <td>
                                            <button
                                                type="button"
                                                class="o_lqa_accounting__pdf_button"
                                                t-att-disabled="!comprobantePdfUrl(item) ? true : undefined"
                                                t-on-click="() => this.openComprobantePdf(item)"
                                            >
                                                <i t-att-class="state.xubio.pdfLoadingTlqv === item.tlqvCode ? 'fa fa-spinner fa-spin' : 'fa fa-file-pdf-o'"/>
                                                PDF
                                            </button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div t-else="" class="o_lqa_accounting__empty">
                            <i class="fa fa-file-o"/>
                            <strong>Sin comprobantes para mostrar</strong>
                            <span>Ajusta los filtros o revisa la configuracion de Madre.</span>
                        </div>
                    </section>
                </t>
            </t>
        </div>
    </t>
</templates>
