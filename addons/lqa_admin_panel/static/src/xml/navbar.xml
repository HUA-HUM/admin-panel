<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t
        t-name="lqa_admin_panel.NavBarBrand"
        t-inherit="web.NavBar"
        t-inherit-mode="extension"
    >
        <xpath expr="//t[@t-call='web.NavBar.AppsMenu']" position="replace">
            <button
                t-if="lqaShouldShowSidebar"
                type="button"
                class="o_lqa_mobile_menu"
                aria-label="Abrir menu"
                title="Abrir menu"
                t-on-click="lqaOpenMobileSidebar"
            >
                <i class="fa fa-bars"/>
            </button>
            <a
                href="/odoo"
                class="o_lqa_navbar_logo"
                aria-label="Tienda Lo Quiero Aca"
                title="Tienda Lo Quiero Aca"
            >
                <img
                    src="/lqa_admin_panel/static/src/img/tienda-logo-navbar.png?v=2"
                    alt="Tienda Lo Quiero Aca"
                />
            </a>
        </xpath>
        <xpath expr="//header" position="after">
            <aside
                t-if="lqaShouldShowSidebar"
                t-att-class="{
                    'o_lqa_sidebar': true,
                    'is-mobile-open': lqaNavigation.mobileOpen
                }"
                aria-label="Navegacion del panel"
            >
                <div class="o_lqa_sidebar__brand">
                    <img
                        src="/lqa_admin_panel/static/src/img/tienda-logo-navbar.png?v=2"
                        alt="Tienda Lo Quiero Aca"
                    />
                    <button
                        type="button"
                        aria-label="Cerrar menu"
                        title="Cerrar menu"
                        t-on-click="lqaCloseMobileSidebar"
                    >
                        <i class="fa fa-times"/>
                    </button>
                </div>

                <nav class="o_lqa_sidebar__nav">
                    <button
                        t-if="currentApp"
                        type="button"
                        class="o_lqa_sidebar__home"
                        t-on-click="lqaOpenPanelHome"
                    >
                        <i class="fa fa-th-large"/>
                        <span>Panel principal</span>
                    </button>

                    <div
                        class="o_lqa_sidebar__group"
                        t-foreach="lqaSidebarSections"
                        t-as="section"
                        t-key="section.id"
                    >
                        <div
                            t-if="section.childrenTree.length"
                            class="o_lqa_sidebar__menu-row"
                        >
                            <button
                                type="button"
                                class="o_lqa_sidebar__group-toggle"
                                t-on-click="() => this.lqaToggleSection(section)"
                            >
                                <span>
                                    <i
                                        t-att-class="section.name === 'MercadoLibre'
                                            ? 'fa fa-shopping-bag'
                                            : section.name === 'Automeli'
                                                ? 'fa fa-cubes'
                                                : section.name === 'Retailers'
                                                    ? 'fa fa-building-o'
                                                    : section.name === 'Comercial'
                                                        ? 'fa fa-briefcase'
                                                    : section.name === 'Administracion'
                                                        ? 'fa fa-calculator'
                                                    : section.name === 'Configuracion'
                                                        ? 'fa fa-sliders'
                                                    : 'fa fa-folder-o'"
                                    />
                                    <t t-esc="section.name"/>
                                </span>
                                <i
                                    t-att-class="lqaIsExpanded(section)
                                        ? 'fa fa-chevron-up'
                                        : 'fa fa-chevron-down'"
                                />
                            </button>
                            <button
                                t-if="lqaCanFavorite(section)"
                                type="button"
                                t-att-class="lqaIsFavorite(section)
                                    ? 'o_lqa_sidebar__favorite is-favorite'
                                    : 'o_lqa_sidebar__favorite'"
                                t-att-title="lqaFavoriteTitle(section)"
                                t-att-aria-label="lqaFavoriteTitle(section)"
                                t-att-disabled="lqaNavigation.favoritePending[section.id]"
                                t-on-click="(event) => this.lqaToggleFavorite(section, event)"
                            >
                                <i
                                    t-att-class="lqaIsFavorite(section)
                                        ? 'fa fa-star'
                                        : 'fa fa-star-o'"
                                />
                            </button>
                        </div>

                        <div
                            class="o_lqa_sidebar__children"
                            t-if="section.childrenTree.length and lqaIsExpanded(section)"
                        >
                            <div
                                t-foreach="section.childrenTree"
                                t-as="child"
                                t-key="child.id"
                                class="o_lqa_sidebar__child"
                            >
                                <div
                                    t-if="child.childrenTree.length"
                                    class="o_lqa_sidebar__menu-row"
                                >
                                    <button
                                        type="button"
                                        class="o_lqa_sidebar__child-toggle"
                                        t-on-click="() => this.lqaToggleSection(child)"
                                    >
                                        <span>
                                            <i
                                                t-att-class="child.name === 'Catalogo'
                                                    ? 'fa fa-th'
                                                       : child.name === 'Marketplaces'
                                                        ? 'fa fa-shopping-cart'
                                                        : child.name === 'Google Merchant'
                                                            ? 'fa fa-google'
                                                        : child.name === 'Publicador'
                                                            ? 'fa fa-cloud-upload'
                                                        : child.name === 'Contable'
                                                            ? 'fa fa-calculator'
                                                        : child.name === 'Clientes'
                                                            ? 'fa fa-users'
                                                        : child.name === 'MercadoLibre'
                                                            ? 'fa fa-shopping-bag'
                                                        : child.name === 'Automeli'
                                                            ? 'fa fa-cubes'
                                                        : child.name === 'Retailers'
                                                            ? 'fa fa-building-o'
                                                        : 'fa fa-folder-o'"
                                            />
                                            <t t-esc="child.name"/>
                                        </span>
                                        <i
                                            t-att-class="lqaIsExpanded(child)
                                                ? 'fa fa-chevron-up'
                                                : 'fa fa-chevron-down'"
                                        />
                                    </button>
                                    <button
                                        t-if="lqaCanFavorite(child)"
                                        type="button"
                                        t-att-class="lqaIsFavorite(child)
                                            ? 'o_lqa_sidebar__favorite is-favorite'
                                            : 'o_lqa_sidebar__favorite'"
                                        t-att-title="lqaFavoriteTitle(child)"
                                        t-att-aria-label="lqaFavoriteTitle(child)"
                                        t-att-disabled="lqaNavigation.favoritePending[child.id]"
                                        t-on-click="(event) => this.lqaToggleFavorite(child, event)"
                                    >
                                        <i
                                            t-att-class="lqaIsFavorite(child)
                                                ? 'fa fa-star'
                                                : 'fa fa-star-o'"
                                        />
                                    </button>
                                </div>
                                <div
                                    t-if="child.childrenTree.length and lqaIsExpanded(child)"
                                    class="o_lqa_sidebar__grandchildren"
                                >
                                    <div
                                        t-foreach="child.childrenTree"
                                        t-as="grandchild"
                                        t-key="grandchild.id"
                                        class="o_lqa_sidebar__grandchild"
                                    >
                                        <div class="o_lqa_sidebar__menu-row">
                                            <button
                                                t-if="grandchild.childrenTree.length"
                                                type="button"
                                                class="o_lqa_sidebar__grandchild-toggle"
                                                t-on-click="() => this.lqaToggleSection(grandchild)"
                                            >
                                                <span>
                                                    <i
                                                        t-att-class="grandchild.name === 'Google Merchant'
                                                            ? 'fa fa-google'
                                                            : 'fa fa-folder-o'"
                                                    />
                                                    <t t-esc="grandchild.name"/>
                                                </span>
                                                <i
                                                    t-att-class="lqaIsExpanded(grandchild)
                                                        ? 'fa fa-chevron-up'
                                                        : 'fa fa-chevron-down'"
                                                />
                                            </button>
                                            <button
                                                t-if="!grandchild.childrenTree.length"
                                                type="button"
                                                class="o_lqa_sidebar__menu-link"
                                                t-on-click="() => this.lqaSelectMenu(grandchild)"
                                            >
                                                <i
                                                    t-att-class="grandchild.name === 'Selecciones'
                                                        ? 'fa fa-folder-open-o'
                                                        : grandchild.name === 'Productos'
                                                            ? 'fa fa-th'
                                                            : grandchild.name === 'Todos los marketplaces'
                                                                ? 'fa fa-th-large'
                                                                : grandchild.name === 'Catalogo'
                                                                    ? 'fa fa-th'
                                                                : grandchild.name === 'Carpetas'
                                                                    ? 'fa fa-folder-open-o'
                                                                    : grandchild.name === 'Publicar'
                                                                        ? 'fa fa-cloud-upload'
                                                                : grandchild.name === 'Seguimiento'
                                                                    ? 'fa fa-list-alt'
                                                                    : grandchild.name === 'Acciones'
                                                                        ? 'fa fa-trash-o'
                                                            : 'fa fa-shopping-cart'"
                                                />
                                                <span t-esc="grandchild.name"/>
                                            </button>
                                            <button
                                                t-if="lqaCanFavorite(grandchild)"
                                                type="button"
                                                t-att-class="lqaIsFavorite(grandchild)
                                                    ? 'o_lqa_sidebar__favorite is-favorite'
                                                    : 'o_lqa_sidebar__favorite'"
                                                t-att-title="lqaFavoriteTitle(grandchild)"
                                                t-att-aria-label="lqaFavoriteTitle(grandchild)"
                                                t-att-disabled="lqaNavigation.favoritePending[grandchild.id]"
                                                t-on-click="(event) => this.lqaToggleFavorite(grandchild, event)"
                                            >
                                                <i
                                                    t-att-class="lqaIsFavorite(grandchild)
                                                        ? 'fa fa-star'
                                                        : 'fa fa-star-o'"
                                                />
                                            </button>
                                        </div>
                                        <div
                                            t-if="grandchild.childrenTree.length and lqaIsExpanded(grandchild)"
                                            class="o_lqa_sidebar__greatgrandchildren"
                                        >
                                            <div
                                                t-foreach="grandchild.childrenTree"
                                                t-as="greatgrandchild"
                                                t-key="greatgrandchild.id"
                                                class="o_lqa_sidebar__menu-row"
                                            >
                                                <button
                                                    type="button"
                                                    class="o_lqa_sidebar__menu-link"
                                                    t-on-click="() => this.lqaSelectMenu(greatgrandchild)"
                                                >
                                                    <i
                                                        t-att-class="greatgrandchild.name === 'Acciones'
                                                            ? 'fa fa-trash-o'
                                                            : greatgrandchild.name === 'Productos'
                                                                ? 'fa fa-th'
                                                                : 'fa fa-circle-o'"
                                                    />
                                                    <span t-esc="greatgrandchild.name"/>
                                                </button>
                                                <button
                                                    t-if="lqaCanFavorite(greatgrandchild)"
                                                    type="button"
                                                    t-att-class="lqaIsFavorite(greatgrandchild)
                                                        ? 'o_lqa_sidebar__favorite is-favorite'
                                                        : 'o_lqa_sidebar__favorite'"
                                                    t-att-title="lqaFavoriteTitle(greatgrandchild)"
                                                    t-att-aria-label="lqaFavoriteTitle(greatgrandchild)"
                                                    t-att-disabled="lqaNavigation.favoritePending[greatgrandchild.id]"
                                                    t-on-click="(event) => this.lqaToggleFavorite(greatgrandchild, event)"
                                                >
                                                    <i
                                                        t-att-class="lqaIsFavorite(greatgrandchild)
                                                            ? 'fa fa-star'
                                                            : 'fa fa-star-o'"
                                                    />
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div
                                    t-if="!child.childrenTree.length"
                                    class="o_lqa_sidebar__menu-row"
                                >
                                    <button
                                        type="button"
                                        class="o_lqa_sidebar__menu-link"
                                        t-on-click="() => this.lqaSelectMenu(child)"
                                    >
                                        <i
                                            t-att-class="child.name === 'Dashboard'
                                                ? 'fa fa-line-chart'
                                                : child.name === 'Catalogo'
                                                    ? 'fa fa-th'
                                                        : child.name === 'Eliminador'
                                                            ? 'fa fa-trash-o'
                                                            : child.name === 'Usuarios'
                                                                ? 'fa fa-users'
                                                                : child.name === 'Pricing'
                                                                    ? 'fa fa-usd'
                                                                    : child.name === 'Central de Promociones'
                                                                        ? 'fa fa-bullhorn'
                                                                        : child.name === 'Marketplaces'
                                                                            ? 'fa fa-shopping-cart'
                                                                            : child.name === 'Orders'
                                                                                ? 'fa fa-list-alt'
                                                                                : child.name === 'Acciones masivas'
                                                                                    ? 'fa fa-bolt'
                                                                                    : child.name === 'Facturacion ARCA'
                                                                                        ? 'fa fa-file-text-o'
                                                                                    : child.name === 'Clientes'
                                                                                        ? 'fa fa-users'
                                                                                    : 'fa fa-circle-o'"
                                        />
                                        <span t-esc="child.name"/>
                                    </button>
                                    <button
                                        t-if="lqaCanFavorite(child)"
                                        type="button"
                                        t-att-class="lqaIsFavorite(child)
                                            ? 'o_lqa_sidebar__favorite is-favorite'
                                            : 'o_lqa_sidebar__favorite'"
                                        t-att-title="lqaFavoriteTitle(child)"
                                        t-att-aria-label="lqaFavoriteTitle(child)"
                                        t-att-disabled="lqaNavigation.favoritePending[child.id]"
                                        t-on-click="(event) => this.lqaToggleFavorite(child, event)"
                                    >
                                        <i
                                            t-att-class="lqaIsFavorite(child)
                                                ? 'fa fa-star'
                                                : 'fa fa-star-o'"
                                        />
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div
                            t-if="!section.childrenTree.length"
                            class="o_lqa_sidebar__menu-row"
                        >
                            <button
                                type="button"
                                class="o_lqa_sidebar__single"
                                t-on-click="() => this.lqaSelectMenu(section)"
                            >
                                <i class="fa fa-cog"/>
                                <span t-esc="section.name"/>
                            </button>
                            <button
                                t-if="lqaCanFavorite(section)"
                                type="button"
                                t-att-class="lqaIsFavorite(section)
                                    ? 'o_lqa_sidebar__favorite is-favorite'
                                    : 'o_lqa_sidebar__favorite'"
                                t-att-title="lqaFavoriteTitle(section)"
                                t-att-aria-label="lqaFavoriteTitle(section)"
                                t-att-disabled="lqaNavigation.favoritePending[section.id]"
                                t-on-click="(event) => this.lqaToggleFavorite(section, event)"
                            >
                                <i
                                    t-att-class="lqaIsFavorite(section)
                                        ? 'fa fa-star'
                                        : 'fa fa-star-o'"
                                />
                            </button>
                        </div>
                    </div>
                </nav>

                <div class="o_lqa_sidebar__footer">
                    <span>Panel Interno</span>
                    <small>Lo Quiero Aca</small>
                </div>
            </aside>
            <button
                t-if="lqaShouldShowSidebar and lqaNavigation.mobileOpen"
                type="button"
                class="o_lqa_sidebar_backdrop"
                aria-label="Cerrar menu"
                t-on-click="lqaCloseMobileSidebar"
            />
        </xpath>
    </t>
</templates>
