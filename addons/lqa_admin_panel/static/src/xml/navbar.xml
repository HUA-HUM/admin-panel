<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t
        t-name="lqa_admin_panel.NavBarBrand"
        t-inherit="web.NavBar"
        t-inherit-mode="extension"
    >
        <xpath expr="//t[@t-call='web.NavBar.AppsMenu']" position="replace">
            <button
                type="button"
                class="o_lqa_mobile_menu"
                aria-label="Abrir menu"
                title="Abrir menu"
                t-on-click="lqaOpenMobileSidebar"
            >
                <i class="fa fa-bars"/>
            </button>
            <a
                href="/odoo"
                class="o_lqa_navbar_logo"
                aria-label="Tienda Lo Quiero Aca"
                title="Tienda Lo Quiero Aca"
            >
                <img
                    src="/lqa_admin_panel/static/src/img/tienda-logo-navbar.png?v=2"
                    alt="Tienda Lo Quiero Aca"
                />
            </a>
        </xpath>
        <xpath expr="//header" position="after">
            <aside
                t-att-class="{
                    'o_lqa_sidebar': true,
                    'is-mobile-open': lqaNavigation.mobileOpen,
                }"
                aria-label="Navegacion del panel"
            >
                <div class="o_lqa_sidebar__brand">
                    <img
                        src="/lqa_admin_panel/static/src/img/tienda-logo-navbar.png?v=2"
                        alt="Tienda Lo Quiero Aca"
                    />
                    <button
                        type="button"
                        aria-label="Cerrar menu"
                        title="Cerrar menu"
                        t-on-click="lqaCloseMobileSidebar"
                    >
                        <i class="fa fa-times"/>
                    </button>
                </div>

                <nav class="o_lqa_sidebar__nav">
                    <button
                        t-if="currentApp"
                        type="button"
                        class="o_lqa_sidebar__home"
                        t-on-click="() => this.lqaSelectMenu(currentApp)"
                    >
                        <i class="fa fa-th-large"/>
                        <span>Panel principal</span>
                    </button>

                    <div
                        class="o_lqa_sidebar__group"
                        t-foreach="lqaSidebarSections"
                        t-as="section"
                        t-key="section.id"
                    >
                        <button
                            t-if="section.childrenTree.length"
                            type="button"
                            class="o_lqa_sidebar__group-toggle"
                            t-on-click="() => this.lqaToggleSection(section)"
                        >
                            <span>
                                <i
                                    t-att-class="section.name === 'MercadoLibre'
                                        ? 'fa fa-shopping-bag'
                                        : section.name === 'Automeli'
                                            ? 'fa fa-cubes'
                                            : section.name === 'Retailers'
                                                ? 'fa fa-building-o'
                                                : 'fa fa-folder-o'"
                                />
                                <t t-esc="section.name"/>
                            </span>
                            <i
                                t-att-class="lqaIsExpanded(section)
                                    ? 'fa fa-chevron-up'
                                    : 'fa fa-chevron-down'"
                            />
                        </button>

                        <div
                            class="o_lqa_sidebar__children"
                            t-if="section.childrenTree.length and lqaIsExpanded(section)"
                        >
                            <div
                                t-foreach="section.childrenTree"
                                t-as="child"
                                t-key="child.id"
                                class="o_lqa_sidebar__child"
                            >
                                <button
                                    t-if="child.childrenTree.length"
                                    type="button"
                                    class="o_lqa_sidebar__child-toggle"
                                    t-on-click="() => this.lqaToggleSection(child)"
                                >
                                    <span>
                                        <i
                                            t-att-class="child.name === 'Catalogo'
                                                ? 'fa fa-th'
                                                : child.name === 'Marketplaces'
                                                    ? 'fa fa-shopping-cart'
                                                    : child.name === 'Publicador'
                                                        ? 'fa fa-cloud-upload'
                                                    : 'fa fa-folder-o'"
                                        />
                                        <t t-esc="child.name"/>
                                    </span>
                                    <i
                                        t-att-class="lqaIsExpanded(child)
                                            ? 'fa fa-chevron-up'
                                            : 'fa fa-chevron-down'"
                                    />
                                </button>
                                <div
                                    t-if="child.childrenTree.length and lqaIsExpanded(child)"
                                    class="o_lqa_sidebar__grandchildren"
                                >
                                    <button
                                        type="button"
                                        t-foreach="child.childrenTree"
                                        t-as="grandchild"
                                        t-key="grandchild.id"
                                        t-on-click="() => this.lqaSelectMenu(grandchild)"
                                    >
                                        <i
                                            t-att-class="grandchild.name === 'Selecciones'
                                                ? 'fa fa-folder-open-o'
                                                : grandchild.name === 'Productos'
                                                    ? 'fa fa-th'
                                                    : grandchild.name === 'Todos los marketplaces'
                                                        ? 'fa fa-th-large'
                                                        : grandchild.name === 'Catalogo'
                                                            ? 'fa fa-th'
                                                        : grandchild.name === 'Carpetas'
                                                            ? 'fa fa-folder-open-o'
                                                            : grandchild.name === 'Publicar'
                                                                ? 'fa fa-cloud-upload'
                                                                : grandchild.name === 'Seguimiento'
                                                                    ? 'fa fa-list-alt'
                                                        : 'fa fa-shopping-cart'"
                                        />
                                        <span t-esc="grandchild.name"/>
                                    </button>
                                </div>
                                <button
                                    t-if="!child.childrenTree.length"
                                    type="button"
                                    t-on-click="() => this.lqaSelectMenu(child)"
                                >
                                    <i
                                        t-att-class="child.name === 'Dashboard'
                                            ? 'fa fa-line-chart'
                                            : child.name === 'Catalogo'
                                                ? 'fa fa-th'
                                                    : child.name === 'Eliminador'
                                                        ? 'fa fa-trash-o'
                                                        : child.name === 'Usuarios'
                                                            ? 'fa fa-users'
                                                            : child.name === 'Pricing'
                                                                ? 'fa fa-usd'
                                                                : child.name === 'Central de Promociones'
                                                                    ? 'fa fa-bullhorn'
                                                                    : child.name === 'Marketplaces'
                                                                        ? 'fa fa-shopping-cart'
                                                                        : child.name === 'Orders'
                                                                            ? 'fa fa-list-alt'
                                                                            : child.name === 'Acciones masivas'
                                                                                ? 'fa fa-bolt'
                                                                                : 'fa fa-circle-o'"
                                    />
                                    <span t-esc="child.name"/>
                                </button>
                            </div>
                        </div>

                        <button
                            t-if="!section.childrenTree.length"
                            type="button"
                            class="o_lqa_sidebar__single"
                            t-on-click="() => this.lqaSelectMenu(section)"
                        >
                            <i class="fa fa-cog"/>
                            <span t-esc="section.name"/>
                        </button>
                    </div>
                </nav>

                <div class="o_lqa_sidebar__footer">
                    <span>Panel Comercial</span>
                    <small>Lo Quiero Aca</small>
                </div>
            </aside>
            <button
                t-if="lqaNavigation.mobileOpen"
                type="button"
                class="o_lqa_sidebar_backdrop"
                aria-label="Cerrar menu"
                t-on-click="lqaCloseMobileSidebar"
            />
        </xpath>
    </t>
</templates>
